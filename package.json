{
  "name": "howlearn-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "deploy:validate": "tsx scripts/validate-deploy-env.ts",
    "quality:gate": "npm run cms:sync && npm run content:validate && npm run problem:validate",
    "prebuild": "npm run deploy:validate && npm run quality:gate",
    "pretina:build": "npm run deploy:validate && npm run quality:gate",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "tina:dev": "tinacms dev -c \"astro dev\"",
    "tina:build": "tinacms build && astro build",
    "cms:sync": "tsx scripts/cms-sync.ts",
    "content:validate": "tsx scripts/validate-content-index.ts",
    "problem:validate": "tsx scripts/validate-problems.ts",
    "smoke:check": "tsx scripts/smoke-check.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.0",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.14.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.4",
    "tinacms": "^3.7.3",
    "unist-util-visit": "^5.1.0",
    "util": "^0.12.5",
    "wrangler": "^4.84.1"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.2.3",
    "pagefind": "^1.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.3"
  }
}
