# 실제 웹앱 도메인 (canonical, sitemap, robots.txt, Open Graph에 사용)
# 검색엔진·SNS 공유 시 노출되는 URL이므로, 앱이 서비스되는 주소로 설정하세요.
NEXT_PUBLIC_SITE_URL=https://howlearn.kr

# 이미지 저장소 도메인 (MDX 상대 경로와 결합, 별도 호스팅 시에만 사용)
# 웹앱과 이미지가 다른 도메인일 때만 설정. 같은 도메인이면 비워두면 됩니다.
NEXT_PUBLIC_IMAGE_BASE_URL=https://howlearn.kr

# Google Analytics 4 측정 ID
NEXT_PUBLIC_GA_ID=

# Google AdSense 클라이언트 ID (예: ca-pub-xxxxxxxxxxxxxxxx)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
