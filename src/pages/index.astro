---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import ArticleListCard from '../components/content/ArticleListCard.astro';
import RecentReads from '../components/content/RecentReads.astro';
import { getFeaturedGuides, getLatestColumns } from '../lib/content-utils';
import { buildOrganizationJsonLd, buildWebSiteJsonLd } from '../lib/seo';

const sections = [
  {
    href: '/guides',
    title: '학부모 가이드',
    desc: '학습 과학 이론을 바탕으로, 가정에서 아이의 공부를 돕는 지도 원칙과 실천 방법을 안내합니다.',
    badgeClass: 'app-badge-type-guide',
    badgeLabel: '학부모',
  },
  {
    href: '/columns',
    title: '수학 학습 칼럼',
    desc: '학생이 수학을 더 효율적으로 공부할 수 있도록, 학습 과학 기반의 전략과 루틴을 제안합니다.',
    badgeClass: 'app-badge-type-column',
    badgeLabel: '칼럼',
  },
  {
    href: '/concepts',
    title: '학습 과학 개념',
    desc: '학습 과학의 핵심 이론 및 개념을 쉽게 설명합니다.',
    badgeClass: 'app-badge-type-concept',
    badgeLabel: '개념',
  },
];

const featuredGuides = await getFeaturedGuides(3);
const latestColumns = await getLatestColumns(3);
const jsonLd = [buildOrganizationJsonLd(), buildWebSiteJsonLd()];
---

<BaseLayout title="HowLearn" description={SITE_DESCRIPTION} jsonLd={jsonLd}>
  <section
    class="container mx-auto max-w-7xl px-4 pb-6 pt-6 sm:px-6 sm:pb-8 sm:pt-10 lg:px-8"
  >
    <div class="app-dashboard-header">
      <p class="app-dashboard-kicker">Learning hub</p>
      <h1 class="app-hero-title">수학, 어떻게 공부해야 할까요?</h1>
      <p class="app-dashboard-subtitle">
        열심히 공부해도 성적이 오르지 않는다면, 방법이 문제일 수 있습니다. HowLearn은 인지과학과 학습 연구를 바탕으로, 실제로 효과가 입증된 공부법을 학부모와 학생 모두가 이해하고 실천할 수 있도록 전달합니다. 학부모를 위한 가이드, 학습 과학 개념 해설, 수학 학습 칼럼까지 — 공부를 '제대로 잘하는 방법'을 한 곳에서 만나보세요.
      </p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/guides" class="app-btn-primary">
        학부모 가이드 보기
      </a>
      <a href="/columns" class="app-btn-outline-primary">
        수학 학습 칼럼 보기
      </a>
      <a href="/concepts" class="app-btn-secondary">
        학습 과학 개념 보기
      </a>
    </div>
  </section>

  {
    featuredGuides.length > 0 && (
      <section class="container mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="app-dashboard-kicker">Featured guides</p>
            <h2 class="text-2xl font-bold tracking-tight text-[var(--fg)]">추천 학부모 가이드</h2>
          </div>
          <a href="/guides" class="text-sm font-semibold text-[var(--accent)] hover:underline">
            전체 가이드 보기
          </a>
        </div>
        <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featuredGuides.map((entry) => (
            <li>
              <ArticleListCard id={entry.id} basePath="/guides" body={entry.body} data={entry.data} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    latestColumns.length > 0 && (
      <section class="container mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="app-dashboard-kicker">Latest columns</p>
            <h2 class="text-2xl font-bold tracking-tight text-[var(--fg)]">최신 수학 학습 칼럼</h2>
          </div>
          <a href="/columns" class="text-sm font-semibold text-[var(--accent)] hover:underline">
            전체 칼럼 보기
          </a>
        </div>
        <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {latestColumns.map((entry) => (
            <li>
              <ArticleListCard id={entry.id} basePath="/columns" body={entry.body} data={entry.data} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="container mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
    <RecentReads title="이어서 읽기" limit={5} />
  </section>

  <section class="container mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold tracking-tight text-[var(--fg)]">
      서비스 구성
    </h2>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        sections.map((s) => (
          <li>
            <a
              href={s.href}
              class="app-card app-card-interactive flex h-full flex-col p-5 text-[var(--fg)]"
            >
              <span class={`app-badge ${s.badgeClass} self-start`}>{s.badgeLabel}</span>
              <h3 class="mt-3 text-lg font-semibold text-[var(--fg)]">
                {s.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--fg-muted)] leading-relaxed">{s.desc}</p>
              <span class="mt-auto inline-flex items-center gap-1 pt-4 text-sm font-semibold text-[var(--accent)]">
                바로가기
                <svg class="app-card-arrow h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
