---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    href: '/guides',
    title: '가이드',
    desc: '학습 과학 기반 학습법/교육 전략 가이드',
  },
  {
    href: '/concepts',
    title: '개념',
    desc: '인지 부하, 분산 학습 등 핵심 개념 사전',
  },
  {
    href: '/books',
    title: '도서',
    desc: '부모·학습자에게 도움이 되는 도서 리뷰',
  },
  {
    href: '/columns',
    title: '칼럼',
    desc: '장기 학습을 돕는 에세이 콘텐츠',
  },
  {
    href: '/problems',
    title: '수학 문제',
    desc: '객관식/단답형 정답 체크 + 단계별 힌트',
  },
  {
    href: '/essay-problems',
    title: '논술 수학',
    desc: '기출 기반 논술 문제 풀이 학습',
  },
];
---

<BaseLayout
  title="HowLearn"
  description="학습 과학 기반 가이드와 수학 문제 풀이를 통합한 학습 플랫폼"
>
  <section
    class="container mx-auto max-w-7xl px-4 pb-12 pt-16 sm:px-6 sm:pt-24 lg:px-8"
  >
    <p class="text-sm font-medium uppercase tracking-wider text-indigo-600 dark:text-indigo-400">
      Learning Science · Math Practice
    </p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-slate-50">
      어떻게 배워야 잘 배우는가
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
      HowLearn은 학습 과학 이론에 기반한 가이드/개념/도서/칼럼과,
      단계별 힌트로 사고력을 키우는 수학 문제 풀이를 하나의 경험으로 제공합니다.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/guides"
        class="rounded-lg bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-400"
      >
        가이드 둘러보기
      </a>
      <a
        href="/problems"
        class="rounded-lg border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-indigo-600 hover:text-indigo-600 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-indigo-400 dark:hover:text-indigo-400"
      >
        문제 풀어보기
      </a>
    </div>
  </section>

  <section class="container mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-50">
      서비스 구성
    </h2>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        sections.map((s) => (
          <li>
            <a
              href={s.href}
              class="block h-full rounded-xl border border-slate-200 bg-white p-5 transition-colors hover:border-indigo-600 hover:shadow-sm dark:border-slate-700 dark:bg-slate-800 dark:hover:border-indigo-400"
            >
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">
                {s.title}
              </h3>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{s.desc}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="container mx-auto max-w-3xl px-4 pb-24 sm:px-6 lg:px-8">
    <article class="prose prose-slate dark:prose-invert">
      <h2>타이포그래피 샘플</h2>
      <p>
        본문은 <code>@tailwindcss/typography</code> 플러그인의 <code>prose</code> 클래스를
        기반으로 긴 글 가독성을 최적화합니다. 인용/코드/목록/표 모두 동일한 톤으로
        정렬됩니다.
      </p>
      <blockquote>
        잘 설계된 타이포그래피는 학습자의 인지 부하를 낮춘다.
      </blockquote>
      <ul>
        <li>학습 과학 기반 콘텐츠 체계</li>
        <li>단계별 힌트 학습 흐름</li>
        <li>오답 노트/북마크/집중 모드</li>
      </ul>
    </article>
  </section>
</BaseLayout>
