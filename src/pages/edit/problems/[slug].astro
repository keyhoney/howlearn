---
import { getCollection } from 'astro:content';
import { getEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import tinaClient from '../../../../tina/__generated__/client';
import ProblemInlineView from '../../../components/tina/ProblemInlineView';

export const getStaticPaths = (async () => {
  const problems = await getCollection('problems');
  return problems
    .filter((entry) => !entry.id.startsWith('_'))
    .map((entry) => ({
      params: { slug: entry.id },
    }));
}) satisfies GetStaticPaths;

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/problems');
}

let tinaResponse;
try {
  tinaResponse = await tinaClient.queries.problems({ relativePath: `${slug}.mdx` });
} catch {
  return Astro.redirect('/problems');
}
const entry = await getEntry('problems', slug);
if (!entry) {
  return Astro.redirect('/problems');
}
const title = entry.data.source ?? `${slug} | ${SITE_TITLE}`;
const description = `${entry.data.year} ${entry.data.examType} 문제 인라인 편집`;
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
  </head>
  <body class="app-shell antialiased">
    <main class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      <ProblemInlineView
        client:load
        query={tinaResponse.query}
        variables={tinaResponse.variables}
        data={tinaResponse.data}
        meta={{
          source: entry.data.source,
          year: entry.data.year,
          month: entry.data.month,
          examType: entry.data.examType,
          subject: entry.data.subject,
          chapter: entry.data.chapter,
          subChapter: entry.data.subChapter,
          concept: entry.data.concept,
          difficulty: entry.data.difficulty,
          answerType: entry.data.answerType,
          answer: entry.data.answer,
        }}
      />
    </main>
  </body>
</html>
