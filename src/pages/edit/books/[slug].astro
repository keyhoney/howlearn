---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import tinaClient from '../../../../tina/__generated__/client';
import BookInlineView from '../../../components/tina/BookInlineView';

export const getStaticPaths = (async () => {
  const books = await getCollection('books');
  return books
    .filter((entry) => !entry.id.startsWith('_'))
    .map((entry) => ({
      params: { slug: entry.id },
    }));
}) satisfies GetStaticPaths;

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/books');
}

let tinaResponse;
try {
  tinaResponse = await tinaClient.queries.books({ relativePath: `${slug}.mdx` });
} catch {
  return Astro.redirect('/books');
}
const title = tinaResponse?.data?.books?.title ?? `${slug} | ${SITE_TITLE}`;
const description = tinaResponse?.data?.books?.summary ?? '도서 인라인 편집';
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
  </head>
  <body class="app-shell antialiased">
    <main class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      <BookInlineView
        client:load
        query={tinaResponse.query}
        variables={tinaResponse.variables}
        data={tinaResponse.data}
      />
    </main>
  </body>
</html>
