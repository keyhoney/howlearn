---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import tinaClient from '../../../../tina/__generated__/client';
import ColumnInlineView from '../../../components/tina/ColumnInlineView';

export const getStaticPaths = (async () => {
  const columns = await getCollection('columns');
  return columns.map((entry) => ({
    params: { slug: entry.id },
  }));
}) satisfies GetStaticPaths;

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/columns');
}

const tinaResponse = await tinaClient.queries.columns({ relativePath: `${slug}.mdx` });
const title = tinaResponse?.data?.columns?.title ?? `${slug} | ${SITE_TITLE}`;
const description = tinaResponse?.data?.columns?.summary ?? '칼럼 인라인 편집';
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
  </head>
  <body class="app-shell antialiased">
    <main class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      <ColumnInlineView
        client:load
        query={tinaResponse.query}
        variables={tinaResponse.variables}
        data={tinaResponse.data}
      />
    </main>
  </body>
</html>
