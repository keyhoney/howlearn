---
import { getCollection } from 'astro:content';
import { getEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import tinaClient from '../../../../tina/__generated__/client';
import EssayProblemInlineView from '../../../components/tina/EssayProblemInlineView';

export const getStaticPaths = (async () => {
  const essayProblems = await getCollection('essay-problems');
  return essayProblems
    .filter((entry) => !entry.id.startsWith('_'))
    .map((entry) => ({
      params: { slug: entry.id },
    }));
}) satisfies GetStaticPaths;

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/essay-problems');
}

let tinaResponse;
try {
  tinaResponse = await tinaClient.queries.essay_problems({ relativePath: `${slug}.mdx` });
} catch {
  return Astro.redirect('/essay-problems');
}
const entry = await getEntry('essay-problems', slug);
if (!entry) {
  return Astro.redirect('/essay-problems');
}
const title = entry.data.source ?? `${slug} | ${SITE_TITLE}`;
const description = `${entry.data.university} 논술 문제 인라인 편집`;
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
  </head>
  <body class="app-shell antialiased">
    <main class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      <EssayProblemInlineView
        client:load
        query={tinaResponse.query}
        variables={tinaResponse.variables}
        data={tinaResponse.data}
        meta={{
          source: entry.data.source,
          year: entry.data.year,
          examType: entry.data.examType,
          university: entry.data.university,
          examYear: entry.data.examYear,
        }}
      />
    </main>
  </body>
</html>
