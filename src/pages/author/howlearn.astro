---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PRIMARY_AUTHOR } from '../../lib/author';
import { buildPersonJsonLd } from '../../lib/seo';

const jsonLd = [buildPersonJsonLd()];
---

<BaseLayout
  title={`${PRIMARY_AUTHOR.name} · 저자 소개`}
  description={PRIMARY_AUTHOR.summary}
  image={PRIMARY_AUTHOR.image}
  jsonLd={jsonLd}
>
  <section class="app-content-wrap">
    <header class="app-card p-6">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
        <img
          src={PRIMARY_AUTHOR.image}
          alt={PRIMARY_AUTHOR.imageAlt}
          width="160"
          height="200"
          class="h-44 w-36 shrink-0 rounded-sm border border-[var(--card-border)] object-cover object-top shadow-sm"
          loading="eager"
        />
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium text-[var(--accent)]">저자 프로필</p>
          <h1 class="app-section-title mt-2">{PRIMARY_AUTHOR.name}</h1>
          <p class="mt-2 text-sm font-medium text-[var(--fg)]">{PRIMARY_AUTHOR.title}</p>
          <p class="mt-3 text-sm leading-relaxed text-[var(--fg-muted)]">
            {PRIMARY_AUTHOR.summary}
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <a href="/about" class="app-btn-secondary inline-flex min-h-10 items-center px-4 text-sm">
              HowLearn 소개
            </a>
            <a href="/guides" class="app-btn-primary inline-flex min-h-10 items-center px-4 text-sm">
              학부모 가이드 보기
            </a>
          </div>
        </div>
      </div>
    </header>

    <section class="app-card mt-4 p-6">
      <h2 class="text-base font-semibold text-[var(--fg)]">경력·자격</h2>
      <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-[var(--fg-muted)]">
        {PRIMARY_AUTHOR.credentials.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="app-card mt-4 p-6">
      <h2 class="text-base font-semibold text-[var(--fg)]">글쓰기·검토 원칙</h2>
      <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-[var(--fg-muted)]">
        <li>교실·상담 현장에서 본 장면을 출발점으로 삼고, 이론은 그 장면을 설명하는 보조 도구로 씁니다.</li>
        <li>연구·가이드 인용 시 가능한 한 원문·기관 링크를 함께 제공합니다.</li>
        <li>중요한 문서는 게시일·검토일을 표시하고, 실제로 수정·검토한 경우에만 날짜를 갱신합니다.</li>
        <li>교육·학습 정보는 참고용이며 진단·치료·상담을 대체하지 않습니다.</li>
      </ul>
    </section>
  </section>
</BaseLayout>
