---
import BaseLayout from '../layouts/BaseLayout.astro';

const formId = String(import.meta.env.PUBLIC_FORMSPREE_FORM_ID || import.meta.env.FORMSPREE_FORM_ID || '').trim();
const formspreeEndpoint = formId ? `https://formspree.io/f/${formId}` : '';
---

<BaseLayout title="문의" description="문의/제안 접수 페이지">
  <section class="app-content-wrap">
    <header class="app-card p-6">
      <h1 class="app-section-title">문의하기</h1>
      <p class="mt-2 text-sm text-[var(--fg-muted)]">
        문제/풀이 질문, 오류 제보, 콘텐츠·협력 제안을 접수합니다.
      </p>
    </header>

    <div class="mt-4 grid gap-4 lg:grid-cols-3">
      <form id="contact-form" class="app-card grid gap-4 p-6 lg:col-span-2" novalidate>
        <label class="grid gap-1 text-sm">
          <span class="font-medium text-[var(--fg)]">문의 유형</span>
          <select name="type" required class="app-select min-h-11">
            <option value="">선택하세요</option>
            <option value="question">문제/풀이 질문</option>
            <option value="bug">사이트 오류 제보</option>
            <option value="proposal">콘텐츠/협력 제안</option>
          </select>
        </label>

        <label class="grid gap-1 text-sm">
          <span class="font-medium text-[var(--fg)]">이메일</span>
          <input
            type="email"
            name="email"
            required
            placeholder="name@example.com"
            class="app-input min-h-11"
          />
        </label>

        <label class="grid gap-1 text-sm">
          <span class="font-medium text-[var(--fg)]">내용</span>
          <textarea
            name="message"
            required
            minlength="10"
            rows="6"
            placeholder="문의 내용을 자세히 입력해 주세요."
            class="app-textarea"
          ></textarea>
        </label>

        <div class="flex flex-wrap items-center gap-2">
          <button type="submit" class="app-btn-primary min-h-11 px-5">
            문의 전송
          </button>
          <button type="reset" class="app-btn-secondary min-h-11">
            초기화
          </button>
          <p id="contact-feedback" class="hidden rounded-md border px-3 py-2 text-sm" role="status" aria-live="polite"></p>
        </div>
      </form>

      <aside class="app-card h-fit p-6">
        <h2 class="text-base font-semibold text-[var(--fg)]">안내</h2>
        <ul class="mt-3 space-y-2 text-sm text-[var(--fg-muted)]">
          <li>평균 답변 시간: 영업일 기준 1~2일</li>
          <li>오류 제보 시 재현 경로를 함께 남겨주세요.</li>
          <li>개인정보는 문의 처리 목적 외 사용하지 않습니다.</li>
        </ul>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="app-badge app-badge-info">문의 접수</span>
          <span class="app-badge app-badge-neutral">검토</span>
          <span class="app-badge app-badge-success">회신</span>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ formspreeEndpoint }}>
  const form = document.getElementById('contact-form');
  const feedback = document.getElementById('contact-feedback');

  function setFeedback(message, ok) {
    if (!feedback) return;
    feedback.classList.remove('hidden');
    feedback.textContent = message;
    feedback.className = ok
      ? 'rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-700 dark:border-emerald-600/40 dark:bg-emerald-500/10 dark:text-emerald-300'
      : 'rounded-md border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700 dark:border-rose-600/40 dark:bg-rose-500/10 dark:text-rose-300';
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const target = event.currentTarget;
    const formData = new FormData(target);
    const type = String(formData.get('type') || '').trim();
    const email = String(formData.get('email') || '').trim();
    const message = String(formData.get('message') || '').trim();

    if (!type || !email || !message) {
      setFeedback('필수 항목을 모두 입력해 주세요.', false);
      return;
    }
    if (!email.includes('@')) {
      setFeedback('이메일 형식이 올바르지 않습니다.', false);
      return;
    }
    if (message.length < 10) {
      setFeedback('문의 내용은 10자 이상 입력해 주세요.', false);
      return;
    }
    if (!formspreeEndpoint) {
      setFeedback('문의 설정이 누락되었습니다. 관리자에게 문의해 주세요.', false);
      return;
    }

    try {
      const response = await fetch(formspreeEndpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify({ type, email, message }),
      });
      const result = await response.json();
      if (!response.ok) {
        setFeedback(result?.error || '문의 전송에 실패했습니다. 다시 시도해 주세요.', false);
        return;
      }
      target.reset();
      setFeedback('문의가 접수되었습니다. 확인 후 안내드리겠습니다.', true);
    } catch {
      setFeedback('문의 전송 중 오류가 발생했습니다. 다시 시도해 주세요.', false);
    }
  });
</script>
