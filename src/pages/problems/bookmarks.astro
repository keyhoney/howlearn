---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const [problems, essayProblems] = await Promise.all([
  getCollection('problems'),
  getCollection('essay-problems'),
]);

const candidates = [
  ...problems.map((p) => ({
    id: p.id,
    href: `/problems/${p.id}`,
    title: p.data.source,
    meta: `${p.data.year}년 ${p.data.month}월 · ${p.data.examType}`,
    type: 'problem',
    typeLabel: '기출',
    year: p.data.year,
    month: p.data.month,
    examType: p.data.examType,
    subject: p.data.subject,
    chapter: p.data.chapter,
    subChapter: p.data.subChapter,
    concept: p.data.concept,
    difficulty: p.data.difficulty,
  })),
  ...essayProblems.map((p) => ({
    id: p.id,
    href: `/essay-problems/${p.id}`,
    title: p.data.source,
    meta: `${p.data.examYear ?? p.data.year}년 · ${p.data.university}`,
    type: 'essay',
    typeLabel: '논술',
    year: p.data.examYear ?? p.data.year,
    month: 0,
    examType: p.data.examType,
    subject: '논술',
    chapter: p.data.university,
    subChapter: '대학별',
    concept: '대학별 고사',
    difficulty: p.data.difficulty,
  })),
];
---

<BaseLayout title="스크랩 모음" description="북마크한 문제 복습 페이지">
  <section class="app-content-wrap py-8 sm:py-10">
    <div class="app-card book-card--compact mb-6 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="type-article-title">스크랩 모음</h1>
        <p class="mt-2 text-sm text-[var(--fg-muted)]">저장 시각(최근순) 기준으로 정렬됩니다.</p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="app-badge app-badge-neutral" id="bookmark-total">0건</span>
        <button type="button" class="app-btn-secondary" id="bookmark-clear">전체 비우기</button>
      </div>
    </div>

    <div class="app-filter-panel">
      <p class="text-sm text-[var(--fg-muted)] leading-relaxed">
        스크랩한 문제를 모아 복습 루틴을 만들 수 있습니다.
      </p>
      <div class="mt-4 app-filter-grid sm:grid-cols-2 lg:grid-cols-3">
        <label class="app-filter-field">
          <span class="app-filter-label">검색어</span>
          <input id="bookmark-keyword" type="search" placeholder="키워드 검색" class="app-input w-full" />
        </label>
        <label class="app-filter-field">
          <span class="app-filter-label">유형</span>
          <select id="bookmark-type" class="app-select w-full">
            <option value="all">전체 유형</option>
            <option value="problem">기출</option>
            <option value="essay">논술</option>
          </select>
        </label>
        <label class="app-filter-field">
          <span class="app-filter-label">정렬</span>
          <select id="bookmark-sort" class="app-select w-full">
            <option value="recent">최근순</option>
            <option value="name">이름순</option>
            <option value="attempts">횟수순</option>
          </select>
        </label>
      </div>
    </div>

    <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="bookmark-list" aria-live="polite"></ul>
    <div
      class="mt-8 hidden rounded-xl border-2 border-dashed border-[var(--card-border)] bg-[var(--surface-2)] px-6 py-10 text-center sm:px-10"
      id="bookmark-empty"
    >
      <p class="text-sm font-medium text-[var(--fg)]">저장된 스크랩이 없습니다.</p>
      <p class="mt-2 text-sm text-[var(--fg-muted)] leading-relaxed">
        문제 상세에서 스크랩 버튼을 누르면 이 목록에 표시됩니다.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ candidates }}>
  const listEl = document.getElementById('bookmark-list');
  const emptyEl = document.getElementById('bookmark-empty');
  const totalEl = document.getElementById('bookmark-total');
  const clearBtn = document.getElementById('bookmark-clear');
  const keywordInput = document.getElementById('bookmark-keyword');
  const typeSelect = document.getElementById('bookmark-type');
  const sortSelect = document.getElementById('bookmark-sort');
  const byId = new Map(candidates.map((v) => [v.id, v]));

  const STAR_PATH =
    'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z';

  function escapeHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function difficultyStarsHtml(value) {
    const n = Math.min(5, Math.max(0, Math.round(Number(value) || 0)));
    let svgs = '';
    for (let i = 0; i < 5; i++) {
      const cls = i < n ? 'app-difficulty-star app-difficulty-star--on' : 'app-difficulty-star app-difficulty-star--off';
      svgs += `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${cls}" aria-hidden="true"><path fill="currentColor" d="${STAR_PATH}" /></svg>`;
    }
    return `<span class="app-difficulty-pill" aria-label="난이도 ${n}단계, 최대 5단계"><span>난이도</span><span class="ml-0.5 flex items-center gap-px" aria-hidden="true">${svgs}</span></span>`;
  }

  function parse(raw, fallback) {
    try {
      return JSON.parse(raw);
    } catch {
      return fallback;
    }
  }

  function readRows() {
    const raw = localStorage.getItem('howlearn-bookmark');
    const store = raw ? parse(raw, { v: 1, byId: {} }) : { v: 1, byId: {} };
    const wrongRaw = localStorage.getItem('howlearn-wrong-note');
    const wrongStore = wrongRaw ? parse(wrongRaw, { v: 1, byId: {} }) : { v: 1, byId: {} };
    return Object.entries(store.byId || {})
      .map(([id, value]) => ({
        id,
        ts: value?.ts ?? 0,
        attempts: wrongStore.byId?.[id]?.entries?.length ?? 0,
      }))
      .filter((row) => row.ts > 0);
  }

  function render() {
    const keyword = String(keywordInput?.value || '').trim().toLowerCase();
    const selectedType = String(typeSelect?.value || 'all');
    const sortBy = String(sortSelect?.value || 'recent');

    let rows = readRows()
      .map((row) => {
        const item = byId.get(row.id);
        return { ...row, item };
      })
      .filter((row) => row.item);

    if (selectedType !== 'all') {
      rows = rows.filter((row) => row.item.type === selectedType);
    }
    if (keyword) {
      rows = rows.filter((row) => {
        const target = `${row.item.title} ${row.item.meta} ${row.item.chapter} ${row.item.subChapter} ${row.item.concept}`.toLowerCase();
        return target.includes(keyword);
      });
    }
    rows.sort((a, b) => {
      if (sortBy === 'name') return a.item.title.localeCompare(b.item.title, 'ko');
      if (sortBy === 'attempts') return b.attempts - a.attempts || b.ts - a.ts;
      return b.ts - a.ts;
    });

    if (totalEl) totalEl.textContent = `${rows.length}건`;

    if (!listEl) return;
    if (rows.length === 0) {
      listEl.innerHTML = '';
      emptyEl?.classList.remove('hidden');
      return;
    }

    emptyEl?.classList.add('hidden');

    listEl.innerHTML = rows
      .map((row) => {
        const it = row.item;
        const when = new Date(row.ts).toLocaleString();
        const ym = Number(it.month) > 0 ? `${it.year}.${String(it.month).padStart(2, '0')}` : `${it.year}`;
        const badgeCls = it.type === 'essay' ? 'app-badge-type-essay' : 'app-badge-type-problem';
        const subtitle = `${it.chapter} · ${it.subChapter} · ${it.concept}`;
        const wrongBadge =
          row.attempts > 0
            ? `<span class="app-badge app-badge-warning">오답 ${row.attempts}회</span>`
            : '';
        return `
          <li>
            <a href="${it.href}" class="app-card app-card-interactive flex h-full flex-col p-5 text-[var(--fg)]">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="app-badge ${badgeCls}">${escapeHtml(it.examType)}</span>
                <span class="font-mono text-xs text-[var(--fg-muted)]">${ym}</span>
              </div>
              <h2 class="mt-3 text-lg font-semibold text-[var(--fg)]">${escapeHtml(it.title)}</h2>
              <p class="mt-2 text-sm text-[var(--fg-muted)] line-clamp-2 leading-relaxed">${escapeHtml(subtitle)}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span class="app-badge app-badge-success">스크랩</span>
                ${wrongBadge}
              </div>
              <div class="mt-3">${difficultyStarsHtml(it.difficulty)}</div>
              <p class="mt-2 text-xs text-[var(--fg-muted)]">저장 시각: ${escapeHtml(when)}</p>
              <div class="mt-auto flex items-center justify-between gap-2 pt-4">
                <span class="text-xs font-medium uppercase tracking-wider text-[var(--accent)]">${escapeHtml(it.subject)}</span>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--accent)]">
                  복습하기
                  <svg class="app-card-arrow h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        `;
      })
      .join('');
  }

  clearBtn?.addEventListener('click', () => {
    localStorage.removeItem('howlearn-bookmark');
    render();
  });
  keywordInput?.addEventListener('input', render);
  typeSelect?.addEventListener('change', render);
  sortSelect?.addEventListener('change', render);

  render();
</script>
