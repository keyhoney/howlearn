---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  buildProblemSubjectChapterTree,
  getPublishedProblems,
} from '../../lib/content-utils';
import DifficultyStars from '../../components/DifficultyStars.astro';
import AppPagination from '../../components/ui/AppPagination.astro';

const allProblems = await getPublishedProblems();
const monthPriority = new Map<number, number>([
  [11, 0], // 수능
  [9, 1],  // 9월 모평
  [6, 2],  // 6월 모평
]);

function extractQuestionNumber(source: string): number {
  const matched = source.match(/(\d+)\s*번(?!.*\d+\s*번)/);
  return matched ? Number.parseInt(matched[1] ?? '', 10) : Number.POSITIVE_INFINITY;
}

const sortedProblems = [...allProblems].sort((a, b) => {
  // 1) 최신 연도 우선
  if (a.data.year !== b.data.year) return b.data.year - a.data.year;

  // 2) 수능(11월) -> 9월 -> 6월 우선, 그 외 월은 뒤로
  const aMonthOrder = monthPriority.get(a.data.month) ?? 999;
  const bMonthOrder = monthPriority.get(b.data.month) ?? 999;
  if (aMonthOrder !== bMonthOrder) return aMonthOrder - bMonthOrder;
  if (a.data.month !== b.data.month) return b.data.month - a.data.month;

  // 3) 문항 번호 오름차순, 동일하면 source 텍스트 오름차순
  const aQ = extractQuestionNumber(a.data.source);
  const bQ = extractQuestionNumber(b.data.source);
  if (aQ !== bQ) return aQ - bQ;
  return a.data.source.localeCompare(b.data.source, 'ko');
});

const subjectChapterTree = buildProblemSubjectChapterTree(allProblems);
const examTypes = Array.from(new Set(sortedProblems.map((p) => p.data.examType)));
const subjects = Object.keys(subjectChapterTree);
const years = Array.from(new Set(sortedProblems.map((p) => p.data.year))).sort((a, b) => b - a);
const months = Array.from(new Set(sortedProblems.map((p) => p.data.month))).sort((a, b) => a - b);
---

<BaseLayout title="수능·모평 수학 문제" description="수능/모의평가 기출 문제 및 단계별 힌트·해설">
  <section class="container mx-auto max-w-7xl px-4 pb-12 pt-4 sm:px-6 sm:pt-6 lg:px-8">
    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="app-section-title">수능·모평 수학 문제</h1>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="app-badge app-badge-info">전체 {sortedProblems.length}</span>
        <span class="app-badge app-badge-neutral">필터 결과 <span data-filtered-count>{sortedProblems.length}</span></span>
      </div>
    </div>

    <form class="app-card mt-6 grid gap-3 p-4 sm:grid-cols-4" data-problem-filter-form>
      <select
        name="examType"
        class="app-select"
      >
        <option value="">전체 시험</option>
        {examTypes.map((v) => <option value={v}>{v}</option>)}
      </select>
      <select name="subject" id="filter-subject" class="app-select">
        <option value="">전체 과목</option>
        {subjects.map((v) => <option value={v}>{v}</option>)}
      </select>
      <select
        name="chapter"
        id="filter-chapter"
        class="app-select"
      >
        <option value="">과목을 먼저 선택</option>
      </select>
      <select
        name="subChapter"
        id="filter-sub-chapter"
        class="app-select"
      >
        <option value="">단원을 먼저 선택</option>
      </select>
      <select
        name="concept"
        id="filter-concept"
        class="app-select"
      >
        <option value="">중단원을 먼저 선택</option>
      </select>
      <select
        name="year"
        class="app-select"
      >
        <option value="">전체 연도</option>
        {years.map((v) => <option value={String(v)}>{v}</option>)}
      </select>
      <select
        name="month"
        class="app-select"
      >
        <option value="">전체 월</option>
        {months.map((v) => <option value={String(v)}>{v}월</option>)}
      </select>
      <select
        name="status"
        class="app-select"
      >
        <option value="all">전체 상태</option>
        <option value="none">미시작</option>
        <option value="progress">진행 중</option>
        <option value="done">완료</option>
      </select>
      <label class="inline-flex items-center gap-2 rounded-sm border border-[var(--card-border)] bg-[var(--surface-1)] px-3 py-2 text-sm text-[var(--fg)]">
        <input type="checkbox" name="wrongOnly" value="1" class="h-4 w-4 accent-[var(--accent)]" />
        오답만
      </label>
      <label class="inline-flex items-center gap-2 rounded-sm border border-[var(--card-border)] bg-[var(--surface-1)] px-3 py-2 text-sm text-[var(--fg)]">
        <input type="checkbox" name="bookmarkedOnly" value="1" class="h-4 w-4 accent-[var(--accent)]" />
        스크랩한 문제만 보기
      </label>
      <button class="app-btn-primary" type="submit">
        필터 적용
      </button>
      <a href="/problems" class="app-btn-secondary">초기화</a>
    </form>

    <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        sortedProblems.map((p) => (
          <li>
            <a
              href={`/problems/${p.id}`}
              data-preserve-list-state-link
              data-problem-card
              data-problem-id={p.id}
              data-exam-type={p.data.examType}
              data-year={p.data.year}
              data-month={p.data.month}
              data-subject={p.data.subject}
              data-chapter={p.data.chapter}
              data-sub-chapter={p.data.subChapter}
              data-concept={p.data.concept}
              class="app-card app-card-interactive flex h-full flex-col p-5 text-[var(--fg)]"
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="app-badge app-badge-type-problem">{p.data.examType}</span>
                <span class="font-mono text-xs text-[var(--fg-muted)]">
                  {p.data.year}.{String(p.data.month).padStart(2, '0')}
                </span>
              </div>
              <h2 class="mt-3 text-lg font-semibold text-[var(--fg)]">
                {p.data.source}
              </h2>
              <p class="mt-2 text-sm text-[var(--fg-muted)] line-clamp-2 leading-relaxed">
                {p.data.chapter} · {p.data.subChapter} · {p.data.concept}
              </p>
              <div class="mt-3">
                <DifficultyStars value={p.data.difficulty} />
              </div>
              <p class="mt-3 flex flex-wrap gap-1.5" data-problem-state></p>
              <div class="mt-auto flex items-center justify-between gap-2 pt-4">
                <span class="text-xs font-medium uppercase tracking-wider text-[var(--accent)]">{p.data.subject}</span>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--accent)]">
                  바로 풀기
                  <svg class="app-card-arrow h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
    <AppPagination mode="client" basePath="/problems" rootId="problems-pagination" />
  </section>
</BaseLayout>

<script is:inline define:vars={{ subjectChapterTree }}>
  (function () {
    const tree = subjectChapterTree;
    const sub = document.getElementById('filter-subject');
    const ch = document.getElementById('filter-chapter');
    const subCh = document.getElementById('filter-sub-chapter');
    const co = document.getElementById('filter-concept');
    const form = document.querySelector('[data-problem-filter-form]');
    const filteredCountEl = document.querySelector('[data-filtered-count]');
    const paginationRoot = document.getElementById('problems-pagination');
    if (!sub || !ch || !subCh || !co || !tree || !form || !filteredCountEl || !paginationRoot) return;
    const perPageOptions = [12, 24, 48];
    const query = new URLSearchParams(window.location.search);
    function getProgressDetail(raw) {
      if (!raw) return { status: 'none', hintRevealedCount: 0, solutionRevealed: false, lastSeenAt: 0 };
      if (typeof raw === 'string') return { status: raw, hintRevealedCount: 0, solutionRevealed: false, lastSeenAt: 0 };
      return {
        status: raw.status || 'none',
        hintRevealedCount: Number(raw.hintRevealedCount || 0),
        solutionRevealed: Boolean(raw.solutionRevealed),
        lastSeenAt: Number(raw.lastSeenAt || 0),
      };
    }

    function normalizeParams(subject, chapter, subChapter, concept) {
      const s = subject.trim();
      let chName = chapter.trim();
      let subChName = subChapter.trim();
      let coName = concept.trim();
      if (!s || !tree[s]) return { subject: '', chapter: '', subChapter: '', concept: '' };
      const chapters = Object.keys(tree[s]);
      if (!chName || !chapters.includes(chName)) return { subject: s, chapter: '', subChapter: '', concept: '' };
      const subChapters = Object.keys(tree[s]?.[chName] ?? {});
      if (!subChName || !subChapters.includes(subChName)) return { subject: s, chapter: chName, subChapter: '', concept: '' };
      const concepts = tree[s]?.[chName]?.[subChName] ?? [];
      if (!coName || !concepts.includes(coName)) return { subject: s, chapter: chName, subChapter: subChName, concept: '' };
      return { subject: s, chapter: chName, subChapter: subChName, concept: coName };
    }

    function setChapterOptions(subj, keepChapter, keepSubChapter, keepConcept) {
      ch.innerHTML = '';
      const opt0 = document.createElement('option');
      opt0.value = '';
      opt0.textContent = subj ? '전체 단원' : '과목을 먼저 선택';
      ch.appendChild(opt0);
      ch.disabled = !subj;
      if (!subj || !tree[subj]) {
        setSubChapterOptions('', '', '', '');
        return;
      }
      for (const name of Object.keys(tree[subj])) {
        const o = document.createElement('option');
        o.value = name;
        o.textContent = name;
        if (keepChapter && name === keepChapter) o.selected = true;
        ch.appendChild(o);
      }
      const selCh = ch.value;
      setSubChapterOptions(subj, selCh, keepSubChapter, keepConcept);
    }

    function setSubChapterOptions(subj, chapterName, keepSubChapter, keepConcept) {
      subCh.innerHTML = '';
      const opt0 = document.createElement('option');
      opt0.value = '';
      opt0.textContent = chapterName ? '전체 중단원' : subj ? '단원을 먼저 선택' : '과목을 먼저 선택';
      subCh.appendChild(opt0);
      subCh.disabled = !chapterName;
      if (!subj || !chapterName || !tree[subj]?.[chapterName]) {
        setConceptOptions('', '', '', '');
        return;
      }
      for (const name of Object.keys(tree[subj][chapterName])) {
        const o = document.createElement('option');
        o.value = name;
        o.textContent = name;
        if (keepSubChapter && name === keepSubChapter) o.selected = true;
        subCh.appendChild(o);
      }
      const selSubCh = subCh.value;
      setConceptOptions(subj, chapterName, selSubCh, keepConcept);
    }

    function setConceptOptions(subj, chapterName, subChapterName, keepConcept) {
      co.innerHTML = '';
      const opt0 = document.createElement('option');
      opt0.value = '';
      opt0.textContent = subChapterName ? '전체 소단원' : chapterName ? '중단원을 먼저 선택' : subj ? '단원을 먼저 선택' : '과목을 먼저 선택';
      co.appendChild(opt0);
      co.disabled = !subChapterName;
      if (!subj || !chapterName || !subChapterName || !tree[subj]?.[chapterName]?.[subChapterName]) return;
      for (const name of tree[subj][chapterName][subChapterName]) {
        const o = document.createElement('option');
        o.value = name;
        o.textContent = name;
        if (keepConcept && name === keepConcept) o.selected = true;
        co.appendChild(o);
      }
    }

    const examType = query.get('examType') ?? '';
    const subject = query.get('subject') ?? '';
    const chapter = query.get('chapter') ?? '';
    const subChapter = query.get('subChapter') ?? '';
    const concept = query.get('concept') ?? '';
    const year = query.get('year') ?? '';
    const month = query.get('month') ?? '';
    const statusFilter = query.get('status') ?? 'all';
    const wrongOnly = query.get('wrongOnly') === '1';
    const bookmarkedOnly = query.get('bookmarkedOnly') === '1';
    const perPageRaw = Number.parseInt(query.get('perPage') ?? '12', 10);
    const perPage = perPageOptions.includes(perPageRaw) ? perPageRaw : 12;
    const pageRaw = Number.parseInt(query.get('page') ?? '1', 10);
    const page = Number.isFinite(pageRaw) && pageRaw > 0 ? pageRaw : 1;
    const normalized = normalizeParams(subject, chapter, subChapter, concept);

    form.querySelector('[name="examType"]').value = examType;
    sub.value = normalized.subject;
    setChapterOptions(normalized.subject, normalized.chapter, normalized.subChapter, normalized.concept);
    form.querySelector('[name="year"]').value = year;
    form.querySelector('[name="month"]').value = month;
    form.querySelector('[name="status"]').value = statusFilter;
    form.querySelector('[name="wrongOnly"]').checked = wrongOnly;
    form.querySelector('[name="bookmarkedOnly"]').checked = bookmarkedOnly;

    sub.addEventListener('change', () => setChapterOptions(sub.value, '', '', ''));
    ch.addEventListener('change', () => setSubChapterOptions(sub.value, ch.value, '', ''));
    subCh.addEventListener('change', () => setConceptOptions(sub.value, ch.value, subCh.value, ''));
    form.addEventListener('submit', () => {
      const pageField = document.createElement('input');
      pageField.type = 'hidden';
      pageField.name = 'page';
      pageField.value = '1';
      form.appendChild(pageField);
    });

    const progress = JSON.parse(localStorage.getItem('howlearn-problem-progress') || '{"byId":{}}');
    const bookmarks = JSON.parse(localStorage.getItem('howlearn-bookmark') || '{"byId":{}}');
    const wrongNotes = JSON.parse(localStorage.getItem('howlearn-wrong-note') || '{"byId":{}}');
    const currentQuery = window.location.search;
    if (currentQuery) {
      document.querySelectorAll('a[data-preserve-list-state-link]').forEach((anchor) => {
        const href = anchor.getAttribute('href');
        if (!href || href.includes('?')) return;
        anchor.setAttribute('href', `${href}${currentQuery}`);
      });
    }
    const visibleItems = [];
    document.querySelectorAll('[data-problem-card]').forEach((el) => {
      const id = el.getAttribute('data-problem-id') || '';
      const detail = getProgressDetail(progress.byId?.[id]);
      const valueStatus = detail.status;
      const bookmarked = Boolean(bookmarks.byId?.[id]);
      const hasWrong = Boolean(wrongNotes.byId?.[id]?.entries?.length);
      const mismatchServerFilter =
        (examType && (el.getAttribute('data-exam-type') || '') !== examType) ||
        (normalized.subject && (el.getAttribute('data-subject') || '') !== normalized.subject) ||
        (normalized.chapter && (el.getAttribute('data-chapter') || '') !== normalized.chapter) ||
        (normalized.subChapter && (el.getAttribute('data-sub-chapter') || '') !== normalized.subChapter) ||
        (normalized.concept && (el.getAttribute('data-concept') || '') !== normalized.concept) ||
        (year && (el.getAttribute('data-year') || '') !== year) ||
        (month && (el.getAttribute('data-month') || '') !== month);
      const mismatchStatus = statusFilter !== 'all' && valueStatus !== statusFilter;
      const mismatchWrong = wrongOnly && !hasWrong;
      const mismatchBookmark = bookmarkedOnly && !bookmarked;
      const li = el.parentElement;
      if (!li) return;
      const stateEl = el.querySelector('[data-problem-state]');
      const labels = [];
      if (valueStatus === 'done') labels.push('<span class="app-badge app-badge-success">완료</span>');
      else if (valueStatus === 'progress') labels.push('<span class="app-badge app-badge-info">진행 중</span>');
      else labels.push('<span class="app-badge app-badge-neutral">미시작</span>');
      if (hasWrong) labels.push('<span class="app-badge app-badge-warning">오답</span>');
      if (bookmarked) labels.push('<span class="app-badge app-badge-info">스크랩</span>');
      if (detail.hintRevealedCount > 0) labels.push(`<span class="app-badge app-badge-info">힌트 ${detail.hintRevealedCount}개</span>`);
      if (detail.solutionRevealed) labels.push('<span class="app-badge app-badge-success">풀이 열람</span>');
      if (detail.lastSeenAt > 0) {
        const d = new Date(detail.lastSeenAt);
        labels.push(`<span class="app-badge app-badge-neutral">${d.getMonth() + 1}/${d.getDate()} 복습</span>`);
      }
      if (stateEl) stateEl.innerHTML = labels.join('');
      const matched = !(mismatchServerFilter || mismatchStatus || mismatchWrong || mismatchBookmark);
      li.classList.toggle('hidden', !matched);
      if (matched) visibleItems.push(li);
    });

    filteredCountEl.textContent = String(visibleItems.length);
    const totalPages = Math.max(1, Math.ceil(visibleItems.length / perPage));
    const currentPage = Math.min(page, totalPages);
    visibleItems.forEach((li, idx) => {
      const show = idx >= (currentPage - 1) * perPage && idx < currentPage * perPage;
      li.classList.toggle('hidden', !show);
    });
    const renderPagination = () => {
      if (typeof window.__howlearnRenderAppPagination !== 'function') return false;
      window.__howlearnRenderAppPagination(paginationRoot, {
        basePath: '/problems',
        currentPage,
        totalPages,
        perPage,
      });
      return true;
    };

    if (!renderPagination()) {
      let retries = 0;
      const maxRetries = 20;
      const tick = () => {
        if (renderPagination()) return;
        retries += 1;
        if (retries < maxRetries) window.setTimeout(tick, 50);
      };
      tick();
    }
  })();
</script>
