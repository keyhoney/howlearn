---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="회원가입" description="HowLearn 회원가입 페이지">
  <section class="mx-auto max-w-lg px-4 py-8">
    <article class="app-card p-6" data-auth-page data-auth-mode="signup">
      <h1 class="text-2xl font-bold tracking-tight text-[var(--fg)]">회원가입</h1>

      <section class="mt-5 rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] p-4">
        <h2 class="text-sm font-semibold text-[var(--fg)]">이메일 회원 가입</h2>
        <p class="mt-1 text-xs text-[var(--fg-muted)]">이메일/비밀번호로 계정 생성</p>
        <div class="mt-3 space-y-3">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-[var(--fg)]">이메일</span>
          <input type="email" autocomplete="email" class="app-input" placeholder="you@example.com" data-auth-email />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-[var(--fg)]">비밀번호</span>
          <input
            type="password"
            autocomplete="new-password"
            class="app-input"
            placeholder="6자 이상 비밀번호"
            data-auth-password
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-[var(--fg)]">비밀번호 확인</span>
          <input
            type="password"
            autocomplete="new-password"
            class="app-input"
            placeholder="비밀번호를 다시 입력"
            data-auth-password-confirm
          />
        </label>
        </div>
        <button type="button" class="app-btn-primary mt-3 w-full" data-auth-email-submit>이메일로 회원가입</button>
      </section>

      <section class="mt-4 rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] p-4">
        <h2 class="text-sm font-semibold text-[var(--fg)]">간편 회원 가입</h2>
        <p class="mt-1 text-xs text-[var(--fg-muted)]">구글 계정으로 즉시 시작</p>
        <button
          type="button"
          class="mt-3 flex w-full items-center justify-center gap-2 rounded-sm border border-[#dadce0] bg-white px-4 py-2 text-sm font-semibold text-[#3c4043] hover:bg-[#f8f9fa] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2"
          data-auth-google
        >
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path
              fill="#EA4335"
              d="M9 7.37v3.66h5.09c-.22 1.18-.9 2.18-1.9 2.86l3.07 2.39c1.79-1.65 2.82-4.07 2.82-6.95 0-.67-.06-1.31-.17-1.94H9Z"
            />
            <path
              fill="#34A853"
              d="M9 18c2.55 0 4.69-.84 6.25-2.28l-3.07-2.39c-.85.57-1.94.91-3.18.91-2.45 0-4.52-1.65-5.26-3.86H.57v2.43A9.44 9.44 0 0 0 9 18Z"
            />
            <path
              fill="#4A90E2"
              d="M3.74 10.38A5.67 5.67 0 0 1 3.45 9c0-.48.1-.95.29-1.38V5.19H.57A9.44 9.44 0 0 0 0 9c0 1.53.37 2.98 1.02 4.19l2.72-2.81Z"
            />
            <path
              fill="#FBBC05"
              d="M9 3.58c1.39 0 2.63.48 3.61 1.41l2.71-2.71C13.69.76 11.55 0 9 0A9.44 9.44 0 0 0 .57 5.19l3.17 2.43C4.48 5.23 6.55 3.58 9 3.58Z"
            />
          </svg>
          구글 로그인
        </button>
      </section>

      <p class="app-feedback app-feedback-info mt-3" data-auth-message>가입 후 대시보드로 이동합니다.</p>
      <p class="mt-4 text-sm text-[var(--fg-muted)]">
        이미 계정이 있나요?
        <a href="/login" class="text-[var(--accent)] hover:underline">로그인으로 이동</a>
      </p>
    </article>
  </section>
</BaseLayout>

<script>
  import '../lib/client/auth-page';
</script>
