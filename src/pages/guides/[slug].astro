---
import MathLayout from '../../layouts/MathLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { getRelatedContent, getPublishedConceptLinkRegistry, getConceptsInArticle } from '../../lib/content-utils';
import ConceptsInArticle from '../../components/content/ConceptsInArticle.astro';
import { mdxContentComponents } from '../../lib/mdx-page-components';
import ConceptTooltipSetup from '../../components/mdx/ConceptTooltipSetup.astro';
import ReadingProgressSetup from '../../components/content/ReadingProgressSetup.astro';
import ReadingTimeBadge from '../../components/content/ReadingTimeBadge.astro';
import ArticleMeta from '../../components/content/ArticleMeta.astro';
import ArticleVisitSetup from '../../components/content/ArticleVisitSetup.astro';
import {
  buildArticleJsonLd,
  buildBreadcrumbJsonLd,
  buildFaqJsonLd,
  buildLearningResourceJsonLd,
} from '../../lib/seo';
import { buildContentPageDescription, buildContentPageTitle } from '../../lib/content-seo';
import { resolveOgImageUrl } from '../../lib/og-image';
import HiddenRepresentativeImage from '../../components/HiddenRepresentativeImage.astro';
import { SITE_URL } from '../../consts';

export const getStaticPaths = (async () => {
  const guides = await getCollection('guides');
  const list = import.meta.env.DEV
    ? guides
    : guides.filter((g) => g.data.status === 'published');
  return list.map((entry) => ({
    params: { slug: entry.id },
  }));
}) satisfies GetStaticPaths;
export const prerender = true;

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/guides');
}
const entry = await getEntry('guides', slug);
if (!entry) {
  return Astro.redirect('/guides');
}
const { Content, headings } = await render(entry);
const { title, summary, description: legacyDescription, intro, publishedAt, faq, references, coverImage, seoTitle, seoDescription } =
  entry.data;
const description = seoDescription ?? summary ?? legacyDescription ?? intro ?? title;
const pageTitle = buildContentPageTitle({
  type: 'guides',
  title,
  summary: description,
  seoTitle,
  seoDescription,
  tags: entry.data.tags,
  categories: entry.data.categories,
});
const pageDescription = buildContentPageDescription({
  type: 'guides',
  title,
  summary: description,
  seoDescription,
  tags: entry.data.tags,
  categories: entry.data.categories,
});
const relatedItems = await getRelatedContent(entry, 4);
const conceptLinkRegistry = await getPublishedConceptLinkRegistry();
const conceptsInArticle = getConceptsInArticle(entry.body ?? '', conceptLinkRegistry, { faq });
const conceptSlugsForVisit = conceptsInArticle
  .filter((c) => c.published)
  .map((c) => ({ slug: c.slug, title: c.title }));
const tocItems = headings.filter((heading) => heading.depth === 2);
const getCollectionLabel = (collection: string) =>
  ({
    guides: '가이드',
    columns: '칼럼',
    concepts: '개념',
    books: '도서',
  })[collection] ?? collection;
const pagePath = `/guides/${entry.id}`;
const pageOgImage = resolveOgImageUrl({
  type: 'guides',
  slug: entry.id,
  coverImage,
  ogImage: entry.data.ogImage,
});
const jsonLd = [
  buildArticleJsonLd({
    title: pageTitle,
    description: pageDescription,
    path: pagePath,
    image: pageOgImage,
    datePublished: publishedAt,
  }),
  buildBreadcrumbJsonLd([
    { name: '홈', item: SITE_URL },
    { name: '가이드', item: new URL('/guides', SITE_URL).toString() },
    { name: title, item: new URL(pagePath, SITE_URL).toString() },
  ]),
  buildLearningResourceJsonLd({
    title: pageTitle,
    description: pageDescription,
    path: pagePath,
    keywords: entry.data.tags,
  }),
  ...(faq && faq.length > 0 ? [buildFaqJsonLd(faq)] : []),
];
---

<MathLayout title={pageTitle} description={pageDescription} image={pageOgImage} jsonLd={jsonLd}>
  <article class="container mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8" data-concept-tooltip-root data-reading-progress-root>
    <HiddenRepresentativeImage src={pageOgImage} />
    <div class="hidden" aria-hidden="true">
      <span data-pagefind-meta="type">guide</span>
      {entry.data.categories?.map((category) => <span data-pagefind-meta="categories">{category}</span>)}
      {entry.data.domains?.map((domain) => <span data-pagefind-meta="domains">{domain}</span>)}
      {entry.data.tags?.map((tag) => <span data-pagefind-meta="tags">{tag}</span>)}
    </div>
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px]">
      <div>
        <header class="app-card mb-8 p-6">
          <p class="text-sm font-medium text-[var(--accent)]">
            <a href="/guides" class="hover:underline" data-list-back-link data-list-base-path="/guides">가이드</a>
            <span class="mx-2 text-[var(--fg-muted)] opacity-50">/</span>
            <span class="text-[var(--fg-muted)]">{entry.id}</span>
          </p>
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-[var(--fg)]">
            {title}
          </h1>
          <ArticleMeta data={entry.data} />
          <div class="mt-4 flex flex-wrap gap-2">
            <ReadingTimeBadge body={entry.body} variant="chip" />
            {entry.data.tags?.slice(0, 3).map((t) => <span class="app-chip">#{t}</span>)}
          </div>
          {intro && (
            <p class="mt-5 text-base leading-relaxed text-[var(--fg-muted)]">
              {intro}
            </p>
          )}
        </header>

        {conceptsInArticle.length > 0 && (
          <section class="app-card mb-8 p-5 lg:hidden">
            <ConceptsInArticle concepts={conceptsInArticle} />
          </section>
        )}

        <div
          class="prose prose-book dark:prose-invert prose-headings:tracking-tight max-w-none app-card p-6"
        >
          <Content components={mdxContentComponents} />
        </div>

        {faq && faq.length > 0 && (
          <section class="app-card mt-8 p-6">
            <h2 class="text-xl font-bold text-[var(--fg)]">FAQ</h2>
            <p class="mt-2 text-sm text-[var(--fg-muted)]">질문을 클릭하면 답변이 펼쳐집니다.</p>
            <div class="mt-4 space-y-3">
              {faq.map((item) => (
                <details class="group rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] p-4">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-3 font-semibold text-[var(--fg)]">
                    <span>{item.question}</span>
                    <span class="text-base font-bold text-[var(--fg)]/80 transition-transform duration-150 group-open:rotate-180">▾</span>
                  </summary>
                  <p class="mt-2 whitespace-pre-wrap text-sm text-[var(--fg-muted)]">{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        {references && references.length > 0 && (
          <section class="app-card mt-8 p-6">
            <h2 class="text-xl font-bold text-[var(--fg)]">참고</h2>
            <ul class="mt-4 space-y-2">
              {references.map((ref) => (
                <li>
                  <a
                    href={ref.url}
                    class="text-[var(--accent)] hover:underline"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {ref.title ?? ref.url}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        {relatedItems.length > 0 && (
          <section class="app-card mt-8 p-6">
            <h2 class="text-xl font-bold text-[var(--fg)]">관련 콘텐츠</h2>
            <ul class="mt-4 grid gap-2">
              {relatedItems.map((item) => (
                <li>
                  <a class="text-sm text-[var(--accent)] hover:underline" href={`/${item.collection}/${item.id}`}>
                    [{getCollectionLabel(item.collection)}] {item.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>

      <aside class="space-y-4 lg:sticky lg:top-20 lg:h-max">
        {tocItems.length > 0 && (
          <section class="app-card hidden p-4 lg:block">
            <h2 class="text-sm font-semibold text-[var(--fg)]">이 글 목차</h2>
            <ul class="mt-3 space-y-2">
              {tocItems.map((item) => (
                <li>
                  <a
                    class="text-sm text-[var(--fg-muted)] hover:text-[var(--accent)]"
                    href={`#${item.slug}`}
                    data-toc-link
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
        {conceptsInArticle.length > 0 && (
          <section class="app-card hidden p-4 lg:block">
            <ConceptsInArticle concepts={conceptsInArticle} />
          </section>
        )}
        <section class="app-card p-4">
          <h2 class="text-sm font-semibold text-[var(--fg)]">도움이 됐다면 공유해 주세요</h2>
          <p class="mt-2 text-sm text-[var(--fg-muted)]">한 번의 공유가 더 많은 학습자에게 큰 도움이 됩니다.</p>
          <div class="mt-3">
            <button
              type="button"
              class="app-btn-secondary w-full inline-flex items-center justify-center gap-2"
              data-browser-share
              data-default-label="지금 공유하기"
              aria-live="polite"
            >
              <span aria-hidden="true">↗</span>
              <span data-share-label>지금 공유하기</span>
            </button>
          </div>
        </section>
      </aside>
    </div>

    <script is:inline>
      (() => {
        const backLink = document.querySelector('[data-list-back-link]');
        if (backLink instanceof HTMLAnchorElement && window.location.search) {
          backLink.href = `${backLink.dataset.listBasePath || '/guides'}${window.location.search}`;
        }

        const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]')).filter(
          (link) => link instanceof HTMLAnchorElement
        );
        if (tocLinks.length > 0) {
          const tocMap = new Map();
          tocLinks.forEach((link) => {
            if (!(link instanceof HTMLAnchorElement)) return;
            const targetId = decodeURIComponent(link.getAttribute('href')?.replace(/^#/, '') || '');
            if (!targetId) return;
            const target = document.getElementById(targetId);
            if (target) tocMap.set(targetId, link);
          });

          const setActive = (activeId) => {
            tocMap.forEach((link, id) => {
              const isActive = id === activeId;
              link.classList.toggle('text-[var(--accent)]', isActive);
              link.classList.toggle('font-semibold', isActive);
              link.classList.toggle('text-[var(--fg-muted)]', !isActive);
            });
          };

          const headingIds = Array.from(tocMap.keys());
          if (headingIds.length > 0) {
            setActive(headingIds[0]);
            const observer = new IntersectionObserver(
              (entries) => {
                const visible = entries
                  .filter((entry) => entry.isIntersecting)
                  .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
                if (visible.length === 0) return;
                const id = visible[0].target.id;
                if (!id) return;
                setActive(id);
              },
              { rootMargin: '-25% 0px -65% 0px', threshold: [0, 0.2, 0.5, 0.8, 1] }
            );

            headingIds.forEach((id) => {
              const target = document.getElementById(id);
              if (target) observer.observe(target);
            });
          }
        }

        const shareBtn = document.querySelector('[data-browser-share]');
        if (!shareBtn) return;
        const shareLabel = shareBtn.querySelector('[data-share-label]');
        const defaultLabel = shareBtn.getAttribute('data-default-label') || '지금 공유하기';
        const pageTitle = document.title;
        const pageUrl = window.location.href;
        const shareText = 'HowLearn 학습 문서를 공유합니다.';

        let feedbackTimer = null;
        const showShareFallback = async () => {
          const existing = document.getElementById('share-fallback-modal');
          if (existing) existing.remove();

          const modal = document.createElement('div');
          modal.id = 'share-fallback-modal';
          modal.style.position = 'fixed';
          modal.style.inset = '0';
          modal.style.background = 'rgba(15, 23, 42, 0.45)';
          modal.style.display = 'grid';
          modal.style.placeItems = 'center';
          modal.style.zIndex = '9999';

          const card = document.createElement('div');
          card.style.width = 'min(92vw, 28rem)';
          card.style.borderRadius = '0.75rem';
          card.style.border = '1px solid #d1d5db';
          card.style.background = '#ffffff';
          card.style.padding = '1rem';
          card.style.boxShadow = '0 12px 30px rgba(2, 6, 23, 0.2)';

          const title = document.createElement('p');
          title.textContent = '링크로 바로 공유하기';
          title.style.margin = '0 0 0.5rem 0';
          title.style.fontWeight = '700';

          const input = document.createElement('input');
          input.type = 'text';
          input.value = pageUrl;
          input.readOnly = true;
          input.style.width = '100%';
          input.style.border = '1px solid #d1d5db';
          input.style.borderRadius = '0.5rem';
          input.style.padding = '0.55rem 0.65rem';

          const actions = document.createElement('div');
          actions.style.display = 'flex';
          actions.style.justifyContent = 'flex-end';
          actions.style.gap = '0.5rem';
          actions.style.marginTop = '0.75rem';

          const closeBtn = document.createElement('button');
          closeBtn.type = 'button';
          closeBtn.textContent = '나중에';
          closeBtn.className = 'app-btn-secondary';

          const copyBtn = document.createElement('button');
          copyBtn.type = 'button';
          copyBtn.textContent = '링크 복사';
          copyBtn.className = 'app-btn-secondary';

          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(pageUrl);
            } catch {
              input.focus();
              input.select();
              document.execCommand('copy');
            }
            copyBtn.textContent = '복사 완료';
            window.setTimeout(() => {
              copyBtn.textContent = '링크 복사';
            }, 1200);
          });

          closeBtn.addEventListener('click', () => modal.remove());
          modal.addEventListener('click', (e) => {
            if (e.target === modal) modal.remove();
          });

          actions.append(closeBtn, copyBtn);
          card.append(title, input, actions);
          modal.append(card);
          document.body.append(modal);

          input.focus();
          input.select();
          try {
            await navigator.clipboard.writeText(pageUrl);
            copyBtn.textContent = '복사 완료';
            window.setTimeout(() => {
              copyBtn.textContent = '링크 복사';
            }, 1200);
          } catch {
            // Keep modal open for manual copy button action.
          }
        };

        const setFeedback = (label, icon, disabledMs = 1400) => {
          shareBtn.setAttribute('aria-busy', 'true');
          shareBtn.setAttribute('disabled', 'true');
          if (shareLabel) shareLabel.textContent = label;
          const iconEl = shareBtn.querySelector('span[aria-hidden="true"]');
          if (iconEl) iconEl.textContent = icon;
          if (feedbackTimer) window.clearTimeout(feedbackTimer);
          feedbackTimer = window.setTimeout(() => {
            shareBtn.removeAttribute('aria-busy');
            shareBtn.removeAttribute('disabled');
            if (shareLabel) shareLabel.textContent = defaultLabel;
            const resetIconEl = shareBtn.querySelector('span[aria-hidden="true"]');
            if (resetIconEl) resetIconEl.textContent = '↗';
          }, disabledMs);
        };

        shareBtn.addEventListener('click', async () => {
          try {
            if (navigator.share) {
              await navigator.share({ title: pageTitle, text: shareText, url: pageUrl });
              setFeedback('공유 완료', '✓');
              return;
            }
            await navigator.clipboard.writeText(pageUrl);
            setFeedback('링크 복사됨', '✓');
          } catch (error) {
            if (error instanceof Error && error.name === 'AbortError') return;
            await showShareFallback();
          }
        });
      })();
    </script>

  </article>
  <ArticleVisitSetup url={pagePath} title={title} domain="guides" conceptSlugs={conceptSlugsForVisit} />
  <ConceptTooltipSetup registry={conceptLinkRegistry} />
  <ReadingProgressSetup />
</MathLayout>
