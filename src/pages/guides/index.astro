---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  filterContentByQuery,
  getAllContent,
  getAvailableTagsForDomain,
  paginateContent,
  sortByDate,
} from '../../lib/content-utils';
import AppPagination from '../../components/ui/AppPagination.astro';

const q = Astro.url.searchParams.get('q') ?? '';
const tag = Astro.url.searchParams.get('tag') ?? '';
const perPageOptions = [12, 24, 48] as const;
const perPageRaw = Number.parseInt(Astro.url.searchParams.get('perPage') ?? '12', 10);
const perPage = perPageOptions.includes(perPageRaw as (typeof perPageOptions)[number]) ? perPageRaw : 12;
const pageRaw = Number.parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const page = Number.isFinite(pageRaw) && pageRaw > 0 ? pageRaw : 1;

const all = await getAllContent();
const filtered = sortByDate(
  filterContentByQuery(all, { q, domain: 'guides', tag: tag || undefined }),
);
const paged = paginateContent(filtered, page, perPage);
const guides = paged.items;
const tags = getAvailableTagsForDomain(all, 'guides');

const buildListHref = (nextPage: number, nextPerPage = perPage) => {
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  if (tag) params.set('tag', tag);
  if (nextPerPage !== 12) params.set('perPage', String(nextPerPage));
  if (nextPage > 1) params.set('page', String(nextPage));
  const qs = params.toString();
  return qs ? `?${qs}` : '/guides';
};
---

<BaseLayout title="학부모 가이드" description="학부모용 가정 학습 지도 조언">
  <section class="container mx-auto max-w-7xl px-4 pb-12 pt-4 sm:px-6 sm:pt-6 lg:px-8">
    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="app-section-title">학부모 가이드</h1>
      </div>
      <span class="app-badge app-badge-info">총 {paged.totalItems}개</span>
    </div>

    <form class="app-card grid gap-3 p-4 sm:grid-cols-4" data-content-filter-form>
      <input
        type="search"
        name="q"
        value={q}
        placeholder="검색어"
        class="app-input sm:col-span-2"
      />
      <select
        name="tag"
        class="app-select"
      >
        <option value="">전체 태그</option>
        {tags.map((t) => <option value={t} selected={tag === t}>{t}</option>)}
      </select>
      <button class="app-btn-primary" type="submit">
        필터 적용
      </button>
    </form>

    {tag && (
      <div class="mt-4">
        <span class="app-chip">선택 태그: {tag}</span>
      </div>
    )}

    <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        guides.map((g) => (
          <li>
            <a
              href={`/guides/${g.id}`}
              data-preserve-list-state-link
              class="app-card app-card-interactive flex h-full flex-col p-5 text-[var(--fg)]"
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="app-badge app-badge-type-guide">학부모</span>
                {g.data.publishedAt && (
                  <time class="font-mono text-xs text-[var(--fg-muted)]">
                    {g.data.publishedAt.toLocaleDateString('ko-KR')}
                  </time>
                )}
              </div>
              <h2 class="mt-3 text-lg font-semibold text-[var(--fg)]">
                {g.data.title}
              </h2>
              <p class="mt-2 text-sm text-[var(--fg-muted)] line-clamp-3 leading-relaxed">
                {g.data.summary}
              </p>
              <div class="mt-auto flex items-center justify-between gap-2 pt-4">
                <p class="text-xs font-medium uppercase tracking-wider text-[var(--accent)]">
                  {g.data.domains?.[0] ?? '학습과학'}
                </p>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--accent)]">
                  자세히 보기
                  <svg class="app-card-arrow h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
    <AppPagination
      currentPage={paged.currentPage}
      totalPages={paged.totalPages}
      perPage={perPage}
      buildHref={(p) => buildListHref(p)}
      buildPerPageHref={(n) => buildListHref(1, n)}
    />
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-content-filter-form]');
    const currentQuery = window.location.search;
    if (currentQuery) {
      document.querySelectorAll('a[data-preserve-list-state-link]').forEach((anchor) => {
        const href = anchor.getAttribute('href');
        if (!href || href.includes('?')) return;
        anchor.setAttribute('href', `${href}${currentQuery}`);
      });
    }
    if (!(form instanceof HTMLFormElement)) return;
    form.addEventListener('submit', () => {
      const pageField = document.createElement('input');
      pageField.type = 'hidden';
      pageField.name = 'page';
      pageField.value = '1';
      form.appendChild(pageField);
    });
  })();
</script>
