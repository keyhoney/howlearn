---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedGuides, sortByDate } from '../../lib/content-utils';

const guides = sortByDate(await getPublishedGuides());
---

<BaseLayout title="가이드" description="학습 과학 기반 가이드 목록">
  <section class="container mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-50">
      가이드
    </h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">
      학습 과학 기반의 실전 가이드 {guides.length}편
    </p>
    <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        guides.map((g) => (
          <li>
            <a
              href={`/guides/${g.id}`}
              class="block h-full rounded-xl border border-slate-200 bg-white p-5 transition-colors hover:border-indigo-600 hover:shadow-sm dark:border-slate-700 dark:bg-slate-800 dark:hover:border-indigo-400"
            >
              <p class="text-xs font-medium uppercase tracking-wider text-indigo-600 dark:text-indigo-400">
                {g.data.domains?.[0] ?? '학습과학'}
              </p>
              <h2 class="mt-2 text-lg font-semibold text-slate-900 dark:text-slate-50">
                {g.data.title}
              </h2>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 line-clamp-3">
                {g.data.summary}
              </p>
              {g.data.publishedAt && (
                <p class="mt-3 text-xs text-slate-400 dark:text-slate-500">
                  {g.data.publishedAt.toLocaleDateString('ko-KR')}
                </p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
