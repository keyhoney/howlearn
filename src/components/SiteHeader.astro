---
import { SITE_TITLE } from '../consts';
import SiteLogoMark from './SiteLogoMark.astro';
---

<header id="app-site-header" class="app-topbar sticky top-0 z-40 w-full">
  <div class="flex h-14 w-full items-center gap-2 px-3 sm:h-16 sm:justify-between sm:gap-3 sm:px-6 2xl:px-10">
    <div class="flex min-w-0 flex-1 items-center gap-2 sm:flex-none lg:hidden">
      <button
        type="button"
        data-sidebar-open
        class="inline-flex h-11 shrink-0 items-center gap-1.5 rounded-md border px-3 text-sm font-semibold shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 lg:hidden"
        style="border-color: color-mix(in srgb, var(--accent) 45%, var(--card-border)); background: color-mix(in srgb, var(--accent) 14%, var(--surface-1)); color: var(--accent);"
        aria-label="메뉴 열기"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="shrink-0">
          <path d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10ZM2.75 14.5a.75.75 0 0 0 0 1.5h14.5a.75.75 0 0 0 0-1.5H2.75Z"></path>
        </svg>
        <span>메뉴</span>
      </button>

      <a
        href="/"
        class="inline-flex min-w-0 flex-1 items-center gap-1.5 truncate text-base font-bold tracking-tight text-[var(--fg)] sm:flex-none sm:text-base lg:hidden"
        aria-label={`${SITE_TITLE} 홈`}
      >
        <SiteLogoMark />
        <span class="inline-flex shrink-0 items-baseline">
          <span style="color:#FF9A32;">How</span>
          <span style="color:#95D6D4;">Learn</span>
        </span>
      </a>
    </div>

    <form
      action="/search"
      method="get"
      class="hidden min-w-0 flex-1 items-center gap-2 rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] pl-3 pr-1 h-10 max-w-xl focus-within:border-[var(--accent)] focus-within:bg-[var(--surface-1)] sm:flex lg:max-w-2xl lg:min-w-[18rem]"
      role="search"
    >
      <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="shrink-0 text-[var(--fg-muted)]">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M9.167 3.333a5.833 5.833 0 1 0 0 11.667 5.833 5.833 0 0 0 0-11.667ZM1.667 9.167a7.5 7.5 0 1 1 15 0 7.5 7.5 0 0 1-15 0Z"/>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M13.286 13.286a.833.833 0 0 1 1.179 0l3.625 3.625a.833.833 0 0 1-1.179 1.178l-3.625-3.625a.833.833 0 0 1 0-1.178Z"/>
      </svg>
      <input
        type="search"
        name="q"
        placeholder="가이드, 개념, 도서 검색"
        enterkeyhint="search"
        class="min-w-0 flex-1 bg-transparent text-sm text-[var(--fg)] placeholder:text-[var(--fg-muted)] focus:outline-none"
        aria-label="통합 검색어"
      />
      <button
        type="submit"
        class="app-btn-primary h-8 shrink-0 px-3 text-xs"
      >
        검색
      </button>
    </form>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <a
        href="/search"
        class="inline-flex h-11 w-11 items-center justify-center rounded-sm border border-[var(--card-border)] text-[var(--fg-muted)] hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 sm:hidden"
        aria-label="검색 페이지로 이동"
      >
        <svg width="22" height="22" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M9.167 3.333a5.833 5.833 0 1 0 0 11.667 5.833 5.833 0 0 0 0-11.667ZM1.667 9.167a7.5 7.5 0 1 1 15 0 7.5 7.5 0 0 1-15 0Z"/>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M13.286 13.286a.833.833 0 0 1 1.179 0l3.625 3.625a.833.833 0 0 1-1.179 1.178l-3.625-3.625a.833.833 0 0 1 0-1.178Z"/>
        </svg>
      </a>

      <button
        type="button"
        data-theme-toggle
        aria-pressed="false"
        aria-label="다크 모드 토글"
        class="relative inline-flex h-7 w-14 items-center rounded-full border border-[var(--card-border)] bg-[var(--surface-2)] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2"
      >
        <span
          data-theme-toggle-thumb
          class="absolute left-[3px] top-[3px] flex h-5 w-5 items-center justify-center rounded-full bg-white text-[var(--fg-muted)] shadow transition-transform"
        >
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-theme-icon-light>
            <path d="M8 12.667A4.667 4.667 0 1 0 8 3.333a4.667 4.667 0 0 0 0 9.334Z"/>
            <path d="M8 1.333v1.334M8 13.333v1.334M2.667 8H1.333M14.667 8h-1.334M3.81 3.81l-.943-.943M13.133 13.133l-.943-.943M3.81 12.19l-.943.943M13.133 2.867l-.943.943" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-theme-icon-dark>
            <path d="M13.5 9.7A5.5 5.5 0 0 1 6.3 2.5a.5.5 0 0 0-.7-.6 6.5 6.5 0 1 0 8.5 8.5.5.5 0 0 0-.6-.7Z"/>
          </svg>
        </span>
        <span class="sr-only" data-theme-toggle-label>다크 모드</span>
      </button>
    </div>
  </div>
</header>

