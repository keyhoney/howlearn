---
import { SITE_TITLE } from '../consts';
---

<header id="app-site-header" class="app-topbar sticky top-0 z-40 w-full">
  <div class="flex h-14 items-center justify-between gap-3 px-4 sm:h-16 sm:px-6 2xl:px-10">
    <div class="flex min-w-0 items-center gap-2">
      <button
        type="button"
        data-sidebar-open
        class="inline-flex h-10 w-10 items-center justify-center rounded-sm border border-[var(--card-border)] text-[var(--fg-muted)] hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 lg:hidden"
        aria-label="사이드바 열기"
      >
        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10ZM2.75 14.5a.75.75 0 0 0 0 1.5h14.5a.75.75 0 0 0 0-1.5H2.75Z"></path>
        </svg>
      </button>

      <a
        href="/"
        class="inline-flex items-center gap-1.5 truncate text-[0.95rem] font-bold tracking-tight text-[var(--fg)] sm:text-base"
        aria-label={`${SITE_TITLE} 홈`}
      >
        <img src="/favicon.png" alt="" class="h-5 w-5 rounded-sm" />
        <span class="inline-flex items-baseline">
          <span style="color:#FF9A32;">How</span>
          <span style="color:#95D6D4;">Learn</span>
        </span>
      </a>

      <form
        action="/search"
        method="get"
        class="ml-2 hidden sm:flex items-center gap-2 rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] px-3 h-10 min-w-[16rem] focus-within:border-[var(--accent)] focus-within:bg-[var(--surface-1)]"
        role="search"
      >
        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="text-[var(--fg-muted)]">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M9.167 3.333a5.833 5.833 0 1 0 0 11.667 5.833 5.833 0 0 0 0-11.667ZM1.667 9.167a7.5 7.5 0 1 1 15 0 7.5 7.5 0 0 1-15 0Z"/>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M13.286 13.286a.833.833 0 0 1 1.179 0l3.625 3.625a.833.833 0 0 1-1.179 1.178l-3.625-3.625a.833.833 0 0 1 0-1.178Z"/>
        </svg>
        <input
          type="search"
          name="q"
          placeholder="가이드, 문제, 개념 검색"
          class="w-full bg-transparent text-sm text-[var(--fg)] placeholder:text-[var(--fg-muted)] focus:outline-none"
          aria-label="통합 검색어"
        />
      </form>
    </div>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <a
        href="/search"
        class="inline-flex min-h-10 items-center rounded-sm border border-[var(--card-border)] px-3 py-2 text-sm font-medium text-[var(--fg-muted)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 sm:hidden"
        aria-label="통합 검색"
      >
        검색
      </a>

      <button
        type="button"
        data-theme-toggle
        aria-pressed="false"
        aria-label="다크 모드 토글"
        class="relative inline-flex h-7 w-14 items-center rounded-full border border-[var(--card-border)] bg-[var(--surface-2)] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2"
      >
        <span
          data-theme-toggle-thumb
          class="absolute left-[3px] top-[3px] flex h-5 w-5 items-center justify-center rounded-full bg-white text-[var(--fg-muted)] shadow transition-transform"
        >
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-theme-icon-light>
            <path d="M8 12.667A4.667 4.667 0 1 0 8 3.333a4.667 4.667 0 0 0 0 9.334Z"/>
            <path d="M8 1.333v1.334M8 13.333v1.334M2.667 8H1.333M14.667 8h-1.334M3.81 3.81l-.943-.943M13.133 13.133l-.943-.943M3.81 12.19l-.943.943M13.133 2.867l-.943.943" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-theme-icon-dark class="hidden">
            <path d="M13.5 9.7A5.5 5.5 0 0 1 6.3 2.5a.5.5 0 0 0-.7-.6 6.5 6.5 0 1 0 8.5 8.5.5.5 0 0 0-.6-.7Z"/>
          </svg>
        </span>
        <span class="sr-only" data-theme-toggle-label>다크 모드</span>
      </button>
    </div>
  </div>
</header>
