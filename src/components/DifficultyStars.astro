---
/**
 * 난이도 1~5: 별 개수 표시 (math_howlearn 패턴)
 * 색상은 global.css --difficulty-* 토큰으로 고대비 고정 (Tailwind orange 팔레트 미정의 대응)
 */
interface Props {
  value: number;
  variant?: 'pill' | 'plain';
  showLabel?: boolean;
  class?: string;
}

const { value, variant = 'pill', showLabel = true, class: className } = Astro.props;
const n = Math.min(5, Math.max(0, Math.round(Number(value) || 0)));

const plain = 'inline-flex items-center gap-0.5 text-[var(--fg-muted)]';
---

<span
  class:list={[variant === 'pill' ? 'app-difficulty-pill' : plain, className]}
  aria-label={`난이도 ${n}단계, 최대 5단계`}
>
  {showLabel && <span>난이도</span>}
  <span class="ml-0.5 flex items-center gap-px" aria-hidden="true">
    {
      [0, 1, 2, 3, 4].map((i) => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class:list={['app-difficulty-star', i < n ? 'app-difficulty-star--on' : 'app-difficulty-star--off']}
          aria-hidden="true"
        >
          <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      ))
    }
  </span>
</span>
