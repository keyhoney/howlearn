---
import { getAdSenseClientIdFromEnv } from '../lib/adsense';

const clientId = import.meta.env.PROD ? getAdSenseClientIdFromEnv() : null;
---

{
  clientId && (
    <script
      is:inline
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${clientId}`}
      crossorigin="anonymous"
    />
  )
}
