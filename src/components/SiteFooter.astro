---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer
  class="mt-16 border-t border-slate-200 bg-slate-50/60 py-10 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-400"
>
  <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center">
      <p>&copy; {year} {SITE_TITLE}. All rights reserved.</p>
      <nav class="flex gap-4" aria-label="보조 메뉴">
        <a href="/about" class="hover:text-indigo-600 dark:hover:text-indigo-400">소개</a>
        <a href="/contact" class="hover:text-indigo-600 dark:hover:text-indigo-400">문의</a>
        <a href="/rss.xml" class="hover:text-indigo-600 dark:hover:text-indigo-400">RSS</a>
      </nav>
    </div>
  </div>
</footer>
