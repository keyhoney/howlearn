---
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer id="app-site-footer" class="border-t border-[var(--card-border)] bg-[var(--surface-1)] py-10 sm:py-12 text-sm text-[var(--fg-muted)]">
  <div class="px-4 sm:px-6 2xl:px-10 mx-auto w-full max-w-[1400px]">
    <div class="grid grid-cols-2 gap-6 sm:gap-8 md:grid-cols-4">
      <div class="col-span-2 min-w-0 md:col-span-1">
        <span class="font-bold tracking-tight text-base sm:text-lg text-[var(--fg)]">{SITE_TITLE}</span>
        <p class="mt-3 sm:mt-4 leading-relaxed">{SITE_DESCRIPTION}</p>
      </div>

      <div>
        <h3 class="mb-3 sm:mb-4 text-sm sm:text-base font-semibold text-[var(--fg)]">탐색</h3>
        <ul class="space-y-2 sm:space-y-3">
          <li><a href="/dashboard" class="hover:text-[var(--accent)] transition-colors">학습 대시보드</a></li>
          <li><a href="/guides" class="hover:text-[var(--accent)] transition-colors">학부모 가이드</a></li>
          <li><a href="/columns" class="hover:text-[var(--accent)] transition-colors">수학 학습 칼럼</a></li>
          <li><a href="/concepts" class="hover:text-[var(--accent)] transition-colors">학습 과학 개념</a></li>
          <li><a href="/books" class="hover:text-[var(--accent)] transition-colors">도서 추천</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 sm:mb-4 text-sm sm:text-base font-semibold text-[var(--fg)]">학습</h3>
        <ul class="space-y-2 sm:space-y-3">
          <li><a href="/problems" class="hover:text-[var(--accent)] transition-colors">수능모평 수학 문제</a></li>
          <li><a href="/essay-problems" class="hover:text-[var(--accent)] transition-colors">대학별 고사 수학 문제</a></li>
          <li><a href="/problems/wrong-note" class="hover:text-[var(--accent)] transition-colors">오답 노트</a></li>
          <li><a href="/problems/bookmarks" class="hover:text-[var(--accent)] transition-colors">스크랩 모음</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 sm:mb-4 text-sm sm:text-base font-semibold text-[var(--fg)]">이용 안내</h3>
        <ul class="space-y-2 sm:space-y-3">
          <li><a href="/about" class="hover:text-[var(--accent)] transition-colors">소개</a></li>
          <li><a href="/contact" class="hover:text-[var(--accent)] transition-colors">문의</a></li>
          <li><a href="/search" class="hover:text-[var(--accent)] transition-colors">검색</a></li>
          <li><a href="/rss.xml" class="hover:text-[var(--accent)] transition-colors">RSS 피드</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 sm:mt-10 pt-6 sm:pt-8 border-t border-[var(--card-border)] text-center">
      © {year} {SITE_TITLE}. 저작권 소유.
    </div>
  </div>
</footer>
