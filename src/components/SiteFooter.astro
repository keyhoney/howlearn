---
import { NAV_LINKS, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
const MGMT_LINKS = [
  { href: '/problems/wrong-note', label: '오답노트' },
  { href: '/problems/bookmarks', label: '스크랩 모음' },
] as const;
const EXPLORE_LINKS = NAV_LINKS.slice(0, 5);
const STUDY_LINKS = [...NAV_LINKS.slice(5), ...MGMT_LINKS];
const ADMIN_UID_ALLOWLIST = String(import.meta.env.PUBLIC_ADMIN_UID_ALLOWLIST || '')
  .split(',')
  .map((item) => item.trim())
  .filter(Boolean);
---

<footer
  id="app-site-footer"
  data-admin-uid-allowlist={ADMIN_UID_ALLOWLIST.join(',')}
  class="border-t border-[var(--card-border)] bg-[var(--surface-1)] py-10 sm:py-12 text-sm text-[var(--fg-muted)]"
>
  <div class="px-4 sm:px-6 2xl:px-10 mx-auto w-full max-w-[1400px]">
    <div class="grid grid-cols-2 gap-6 sm:gap-8 md:grid-cols-4">
      <div class="col-span-2 min-w-0 md:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 font-bold tracking-tight text-base sm:text-lg" aria-label={`${SITE_TITLE} 홈`}>
          <img src="/favicon.png" alt="" class="h-5 w-5 rounded-sm" />
          <span class="inline-flex items-baseline">
            <span style="color:#FF9A32;">How</span>
            <span style="color:#95D6D4;">Learn</span>
          </span>
        </a>
        <p class="mt-3 sm:mt-4 leading-relaxed">{SITE_DESCRIPTION}</p>
      </div>

      <div>
        <h3 class="mb-3 sm:mb-4 text-sm sm:text-base font-semibold text-[var(--fg)]">탐색</h3>
        <ul class="space-y-2 sm:space-y-3">
          {
            EXPLORE_LINKS.map((link) => (
              <li><a href={link.href} class="hover:text-[var(--accent)] transition-colors">{link.label}</a></li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="mb-3 sm:mb-4 text-sm sm:text-base font-semibold text-[var(--fg)]">학습</h3>
        <ul class="space-y-2 sm:space-y-3">
          {
            STUDY_LINKS.map((link) => (
              <li><a href={link.href} class="hover:text-[var(--accent)] transition-colors">{link.label}</a></li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="mb-3 sm:mb-4 text-sm sm:text-base font-semibold text-[var(--fg)]">이용 안내</h3>
        <ul class="space-y-2 sm:space-y-3">
          <li><a href="/about" class="hover:text-[var(--accent)] transition-colors">소개</a></li>
          <li><a href="/contact" class="hover:text-[var(--accent)] transition-colors">문의</a></li>
          <li><a href="/privacy" class="hover:text-[var(--accent)] transition-colors">개인정보처리방침</a></li>
          <li><a href="/cookies" class="hover:text-[var(--accent)] transition-colors">쿠키 정책</a></li>
          <li><a href="/terms" class="hover:text-[var(--accent)] transition-colors">이용약관</a></li>
          <li><a href="/disclaimer" class="hover:text-[var(--accent)] transition-colors">면책 조항</a></li>
          <li><a href="/search" class="hover:text-[var(--accent)] transition-colors">검색</a></li>
          <li class="hidden" data-admin-only-link>
            <a href="/admin/sync-usage" class="hover:text-[var(--accent)] transition-colors">운영 지표</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 sm:mt-10 pt-6 sm:pt-8 border-t border-[var(--card-border)] text-center">
      © {year} {SITE_TITLE}. 저작권 소유.
    </div>
  </div>
</footer>
<script>
  import '../lib/client/footer-admin-link';
</script>
