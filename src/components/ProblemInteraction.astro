---
interface Props {
  /** 힌트 단계별 HTML(신뢰 출처 MDX만) */
  hintStepsHtml: string[];
  /** 풀이 HTML(신뢰 출처 MDX만) */
  solutionHtml: string;
}

const {
  hintStepsHtml,
  solutionHtml,
} = Astro.props;
---

<section class="not-prose mt-6 app-card p-5">
  <h2 class="text-lg font-bold text-[var(--fg)]">힌트 및 풀이</h2>

  <div class="mt-4 rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] p-4">
    <div class="flex items-center justify-between gap-2">
      <h3 class="text-sm font-semibold text-[var(--fg)]">STEP 힌트</h3>
    </div>
    {hintStepsHtml.length > 0 ? (
      <ul class="mt-3 grid gap-2" data-hint-list>
        {hintStepsHtml.map((html, idx) => (
          <li class="app-hint-step-card" data-hint-step data-step-index={idx}>
            <button
              type="button"
              class="app-hint-step-trigger"
              data-hint-trigger
              data-step-index={idx}
              aria-expanded="false"
            >
              <strong>STEP {idx + 1}</strong>
              <span class="app-hint-step-meta">
                <span class="app-hint-step-icon" data-hint-step-icon aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" class="hidden h-4 w-4" data-icon-eye>
                    <path d="M2 12C3.7 8.7 7.2 6.5 12 6.5C16.8 6.5 20.3 8.7 22 12C20.3 15.3 16.8 17.5 12 17.5C7.2 17.5 3.7 15.3 2 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                    <circle cx="12" cy="12" r="2.3" fill="currentColor"></circle>
                  </svg>
                  <span data-icon-check class="hidden">✓</span>
                </span>
                <span data-hint-step-state>잠김</span>
              </span>
            </button>
            <div
              class="prose prose-sm prose-slate dark:prose-invert mt-2 hidden max-w-none text-[var(--fg)]"
              data-hint-content
              set:html={html}
            />
          </li>
        ))}
      </ul>
    ) : (
      <p class="mt-3 rounded-sm border border-[var(--card-border)] bg-[var(--surface-1)] px-3 py-2 text-sm text-[var(--fg-muted)]">
        이 문제는 힌트가 없습니다.
      </p>
    )}
    <button type="button" class="hidden" data-reveal-hint aria-hidden="true" tabindex="-1"></button>
  </div>

  <div class="mt-4 rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] p-4">
    <div class="flex items-center justify-between gap-2">
      <h3 class="text-sm font-semibold text-[var(--fg)]">최종 풀이</h3>
      <button
        type="button"
        class="app-btn-outline-primary"
        data-reveal-solution
      >
        풀이 공개
      </button>
    </div>
    <p class="mt-2 text-xs text-[var(--fg-muted)]" data-solution-gate role="status" aria-live="polite">
      모든 STEP 힌트를 공개하면 풀이를 열 수 있습니다.
    </p>
    <div
      class="prose prose-sm prose-slate dark:prose-invert mt-3 hidden max-w-none rounded-sm border border-[var(--card-border)] bg-[var(--surface-1)] px-3 py-2 text-[var(--fg)]"
      data-solution
      set:html={solutionHtml}
    />
  </div>
</section>
