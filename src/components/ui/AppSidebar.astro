---
import { NAV_LINKS, SITE_TITLE } from '../../consts';

interface Props {
  pathname: string;
  compact?: boolean;
  iconOnly?: boolean;
}

const { pathname, compact = false, iconOnly = false } = Astro.props;
const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));

const NAV_ICONS: Record<string, string> = {
  '/dashboard':
    '<path d="M4.5 4.5h13v13h-13z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M8 13V9M11 13V7M14 13v-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M8 6.5h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>',
  '/guides':
    '<circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="11" cy="11" r="1.1" fill="currentColor"/><path d="M11 11 14.6 7.4l-1.8 5-5 1.8L11 11Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>',
  '/concepts':
    '<path d="M11 3.8a5.6 5.6 0 0 0-3.9 9.7c.6.55 1.1 1.3 1.1 2.1h5.6c0-.8.5-1.55 1.1-2.1A5.6 5.6 0 0 0 11 3.8Z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M8.9 17h4.2M9.4 19h3.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>',
  '/books':
    '<path d="M3 4.5A1.5 1.5 0 0 1 4.5 3H10v15H4.5A1.5 1.5 0 0 1 3 16.5v-12Z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M19 4.5A1.5 1.5 0 0 0 17.5 3H12v15h5.5a1.5 1.5 0 0 0 1.5-1.5v-12Z" stroke="currentColor" stroke-width="1.4" fill="none"/>',
  '/columns':
    '<path d="M4.5 5.5h13v11h-13z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M7.5 8.5h7M7.5 11h7M7.5 13.5h4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>',
  '/problems':
    '<path d="M5 4.5h12v13H5z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="m8 9 1.3 1.3L12 7.6M8 13 9.3 14.3 12 11.6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.8 9H15M13.8 13H15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>',
  '/essay-problems':
    '<path d="M5 16.5 14.5 7l2.5 2.5L7.5 19l-3 .5.5-3Z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/><path d="M13 8.5 16 11.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>',
};

const MGMT_LINKS = [
  {
    href: '/problems/wrong-note',
    label: '오답노트',
    icon:
      '<path d="M5 4.5h10l3 3v11A1.5 1.5 0 0 1 16.5 20h-11A1.5 1.5 0 0 1 4 18.5v-13A1 1 0 0 1 5 4.5Z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="m9 12 2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  {
    href: '/problems/bookmarks',
    label: '스크랩 모음',
    icon:
      '<path d="M6 3.5h9A1.5 1.5 0 0 1 16.5 5v15l-5-3.5L6.5 20V5A1.5 1.5 0 0 1 8 3.5Z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/>',
  },
];
---

<aside
  class:list={[
    'app-sidebar flex h-full flex-col',
    iconOnly ? 'w-16 shrink-0' : compact ? 'w-full' : 'w-72 shrink-0',
  ]}
>
  {
    iconOnly ? (
      <div class="flex items-center justify-center border-b border-[var(--sidebar-border)] px-2 py-4">
        <a href="/" class="inline-flex h-9 w-9 items-center justify-center rounded-sm border border-[var(--sidebar-border)] text-sm font-bold text-white">
          {SITE_TITLE.slice(0, 1)}
        </a>
      </div>
    ) : (
      <div class="flex items-center justify-between gap-2 px-6 py-5 border-b border-[var(--sidebar-border)]">
        <a href="/" class="flex flex-col leading-tight">
          <span class="text-lg font-bold tracking-tight text-white">{SITE_TITLE}</span>
          <span class="text-[11px] uppercase tracking-[0.18em] text-[var(--sidebar-fg-muted)]">Learning Dashboard</span>
        </a>
      </div>
    )
  }

  <nav class:list={['flex-1 overflow-y-auto py-6', iconOnly ? 'px-2' : 'px-4']} aria-label="사이드 메뉴">
    {!iconOnly && <h3 class="app-sidebar-section-title">학습</h3>}
    <ul class="mb-6 flex flex-col gap-1">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              title={iconOnly ? link.label : undefined}
              data-icon-label={iconOnly ? link.label : undefined}
              aria-label={link.label}
              class:list={['app-sidebar-link', iconOnly && 'app-sidebar-link-icon justify-center px-2']}
            >
              <svg width="18" height="18" viewBox="0 0 22 22" aria-hidden="true" set:html={NAV_ICONS[link.href] ?? ''} />
              {!iconOnly && <span>{link.label}</span>}
            </a>
          </li>
        ))
      }
    </ul>

    {!iconOnly && <h3 class="app-sidebar-section-title">학습 관리</h3>}
    <ul class="flex flex-col gap-1">
      {
        MGMT_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              title={iconOnly ? link.label : undefined}
              data-icon-label={iconOnly ? link.label : undefined}
              aria-label={link.label}
              class:list={['app-sidebar-link', iconOnly && 'app-sidebar-link-icon justify-center px-2']}
            >
              <svg width="18" height="18" viewBox="0 0 22 22" aria-hidden="true" set:html={link.icon} />
              {!iconOnly && <span>{link.label}</span>}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  {!iconOnly && (
    <div class="border-t border-[var(--sidebar-border)] px-5 py-4 text-xs text-[var(--sidebar-fg-muted)] flex items-center gap-3">
      <a href="/about" class="hover:text-white">소개</a>
      <span>·</span>
      <a href="/contact" class="hover:text-white">문의</a>
      <a href="/search" class="ml-auto hover:text-white">검색</a>
    </div>
  )}
</aside>
