---
import type { ConceptMention } from '@/lib/concept-links';

interface Props {
  concepts: ConceptMention[];
}

const { concepts } = Astro.props;
---

{
  concepts.length > 0 && (
    <div aria-label="이 글에서 다룬 개념">
      <h2 class="text-sm font-semibold text-[var(--fg)]">이 글에서 다룬 개념</h2>
      <p class="mt-1 text-xs leading-relaxed text-[var(--fg-muted)]">
        본문에 연결된 학습 과학 개념 {concepts.length}개
      </p>
      <ul class="mt-3 space-y-2">
        {concepts.map((concept) => (
          <li>
            {concept.published ? (
              <a
                href={`/concepts/${concept.slug}`}
                class="hl-concept-hub-link group block rounded-sm border border-[var(--card-border)] bg-[var(--surface-2)] px-3 py-2.5 no-underline transition hover:border-[var(--accent)] hover:bg-[color-mix(in_srgb,var(--accent)_6%,var(--surface-2))]"
              >
                <span class="block text-sm font-semibold leading-snug text-[var(--fg)] group-hover:text-[var(--accent)]">
                  {concept.title}
                </span>
                {concept.englishName && (
                  <span class="mt-0.5 block text-xs italic text-[var(--fg-muted)] group-hover:text-[var(--accent)]">
                    {concept.englishName}
                  </span>
                )}
              </a>
            ) : (
              <span
                class="hl-concept-unpublished block rounded-sm border border-dashed border-[var(--card-border)] bg-[var(--surface-2)] px-3 py-2.5 text-sm text-[var(--fg-muted)]"
                title="콘텐츠 준비 중입니다"
              >
                {concept.title}
                <span class="ml-1 text-xs">(준비 중)</span>
              </span>
            )}
          </li>
        ))}
      </ul>
    </div>
  )
}
