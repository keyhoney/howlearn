---
import ReadingTimeBadge from './ReadingTimeBadge.astro';
import { resolveArticleListCardMeta, type ArticleListCardInput } from '@/lib/card-meta';
import { getCategoryBadgeClass } from '@/lib/category-badge';

interface Props {
  id: string;
  basePath: '/guides' | '/columns' | '/books';
  body?: string;
  data: ArticleListCardInput;
}

const { id, basePath, body, data } = Astro.props;
const meta = resolveArticleListCardMeta(data);
const hasFooterMeta = meta.footerTags.length > 0 || body;
const hasHeaderRow = meta.headerBadges.length > 0 || data.publishedAt;
---

<a
  href={`${basePath}/${id}`}
  data-preserve-list-state-link
  class="app-card app-card-interactive flex h-full flex-col p-5 text-[var(--fg)]"
>
  {
    hasHeaderRow && (
      <div class="flex flex-wrap items-start justify-between gap-2">
        {
          meta.headerBadges.length > 0 ? (
            <div class="flex flex-wrap gap-1.5">
              {meta.headerBadges.map((badge) => (
                <span class:list={['app-badge', getCategoryBadgeClass(badge)]}>{badge}</span>
              ))}
            </div>
          ) : (
            <span aria-hidden="true" />
          )
        }
        {data.publishedAt && (
          <time class="font-mono text-xs text-[var(--fg-muted)]" datetime={data.publishedAt.toISOString()}>
            {data.publishedAt.toLocaleDateString('ko-KR')}
          </time>
        )}
      </div>
    )
  }

  <h2 class:list={['text-lg font-semibold text-[var(--fg)]', hasHeaderRow ? 'mt-3' : '']}>
    {meta.displayTitle}
  </h2>
  {
    meta.excerpt && (
      <p class="mt-2 text-sm text-[var(--fg-muted)] line-clamp-3 leading-relaxed">{meta.excerpt}</p>
    )
  }

  <div class="mt-auto flex items-end justify-between gap-3 pt-4">
    {
      hasFooterMeta ? (
        <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1.5">
          {meta.footerTags.map((tag) => (
            <span class="app-chip app-card-footer-tag max-w-full truncate">#{tag}</span>
          ))}
          {meta.footerTags.length > 0 && body && (
            <span class="hidden text-[var(--fg-muted)] opacity-40 sm:inline" aria-hidden="true">
              ·
            </span>
          )}
          <ReadingTimeBadge body={body} variant="list-footer" />
        </div>
      ) : (
        <span aria-hidden="true" />
      )
    }
    <span class="inline-flex shrink-0 items-center gap-1 text-sm font-semibold text-[var(--accent)]">
      자세히 보기
      <svg class="app-card-arrow h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path
          fill-rule="evenodd"
          d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
          clip-rule="evenodd"></path>
      </svg>
    </span>
  </div>
</a>
