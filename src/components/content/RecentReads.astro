---
interface Props {
  title?: string;
  limit?: number;
  class?: string;
  variant?: 'default' | 'sidebar';
}

const { title = '최근 읽은 글', limit = 5, class: className = '', variant = 'default' } = Astro.props;
const isSidebar = variant === 'sidebar';
---

<section
  class:list={[isSidebar ? 'app-sidebar-recent-reads' : ['app-card p-4', className]]}
  data-recent-reads-root
  data-recent-reads-variant={variant}
  data-limit={limit}
>
  <h2
    class:list={[
      'text-sm font-bold tracking-tight',
      isSidebar ? 'app-sidebar-section-title !px-0 !pb-2' : 'text-[var(--fg)]',
    ]}
  >
    {title}
  </h2>
  <p
    class:list={[
      'mt-2 hidden text-xs leading-relaxed',
      isSidebar ? 'text-[var(--sidebar-fg-muted)]' : 'text-[var(--fg-muted)]',
    ]}
    data-recent-reads-empty
  >
    아직 읽은 글이 없습니다.
  </p>
  <ul class="mt-2 space-y-1" data-recent-reads-list></ul>
</section>

<script>
  import { initRecentReads } from '../../lib/client/recent-reads-ui';

  document.addEventListener('DOMContentLoaded', initRecentReads);
</script>
