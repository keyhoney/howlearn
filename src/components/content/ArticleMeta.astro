---
import {
  formatArticleDate,
  getRevisionKindLabel,
  resolveArticleMeta,
  type ArticleMetaInput,
} from '@/lib/article-meta';
import { PRIMARY_AUTHOR } from '@/lib/author';

interface Props {
  data: ArticleMetaInput;
}

const { data } = Astro.props;
const meta = resolveArticleMeta(data);
const authorProfileHref = `/author/${PRIMARY_AUTHOR.slug}`;

const hasMeta = Boolean(
  meta.publishedAt || meta.latestRevision || meta.author,
);
---

{
  hasMeta && (
    <div class="app-article-meta mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-[var(--fg-muted)]">
      {meta.publishedAt && (
        <span>
          <span class="font-medium text-[var(--fg)]">게시</span>{' '}
          <time datetime={meta.publishedAt.toISOString()}>{formatArticleDate(meta.publishedAt)}</time>
        </span>
      )}
      {meta.latestRevision && (
        <>
          <span class="text-[var(--fg-muted)] opacity-40" aria-hidden="true">
            ·
          </span>
          <span>
            <span class="font-medium text-[var(--fg)]">
              {getRevisionKindLabel(meta.latestRevision.kind)}
            </span>{' '}
            <time datetime={meta.latestRevision.date.toISOString()}>
              {formatArticleDate(meta.latestRevision.date)}
            </time>
          </span>
        </>
      )}
      {meta.author && (
        <>
          <span class="text-[var(--fg-muted)] opacity-40" aria-hidden="true">
            ·
          </span>
          <span>
            <span class="font-medium text-[var(--fg)]">글</span>{' '}
            <a href={authorProfileHref} class="text-[var(--accent)] hover:underline">
              {meta.author}
            </a>
            <span class="text-[var(--fg-muted)]"> · {PRIMARY_AUTHOR.title}</span>
          </span>
        </>
      )}
    </div>
  )
}
